{% extends 'base.html.twig' %}

{% block title %}{{ item.title }} | {{ storeName|default('Autoparnet') }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-[#e8f2ec] flex flex-col font-sans">
  
  <!-- Simple Header -->
  <header class="bg-[#0b141a] h-20 flex items-center px-6 shadow-xl">
      <a href="javascript:history.back()" class="text-white hover:text-[#25d366] flex items-center gap-2 font-bold uppercase tracking-widest text-xs transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Volver al catálogo
      </a>
  </header>

  <!-- Product Container -->
  <main class="max-w-5xl mx-auto w-full px-6 py-12 flex-1 flex flex-col">
      <div class="bg-white rounded-[3rem] p-8 shadow-2xl flex flex-col md:flex-row gap-12 flex-1">
          
          <!-- Image -->
          <div class="flex-1 bg-[#f8fafc] rounded-[2rem] p-8 flex items-center justify-center border border-slate-100">
              {% set extras = item.extras|default({}) %}
              {% set mainImg = extras.pathImg is defined and extras.pictures is defined and extras.pictures|length > 0 
                  ? extras.pathImg ~ '/' ~ extras.pictures[0] 
                  : item.thumb %}
              <img src="{{ mainImg }}" alt="{{ item.title }}" class="w-full h-auto max-h-[500px] object-contain rounded-xl hover:scale-105 transition-transform duration-700">
          </div>

          <!-- Details -->
          <div class="flex-1 flex flex-col justify-center">
              <span class="text-xs font-black text-slate-400 tracking-widest uppercase mb-3 inline-block bg-slate-100 px-3 py-1 rounded-full w-fit">
                  REF: {{ item.iku|default('N/A') }}/{{ item.id }}
              </span>
              <h1 class="text-3xl lg:text-4xl font-black text-[#103928] leading-tight mb-6">{{ item.title }}</h1>
              
              <div class="mb-8">
                  <span class="text-xs text-slate-500 font-bold uppercase tracking-widest block mb-1">Precio Neto</span>
                  <span class="text-5xl font-black text-[#103928] italic">${{ item.price|number_format(2, '.', ',') }}</span>
              </div>

              {% if item.detalles %}
              <div class="mb-8">
                  <h3 class="text-xs font-black text-slate-400 tracking-widest uppercase mb-2">Detalles del producto</h3>
                  <p class="text-sm text-slate-600 leading-relaxed bg-slate-50 p-4 rounded-2xl border border-slate-100">{{ item.detalles }}</p>
              </div>
              {% endif %}

              <div class="flex gap-4 mt-auto">
                  <button class="flex-1 bg-[#25d366] text-[#0b141a] font-black py-5 rounded-2xl uppercase tracking-widest hover:bg-emerald-400 transition-colors shadow-xl shadow-[#25d366]/20 active:scale-95">
                      Consultar / Comprar
                  </button>
              </div>
          </div>

      </div>
  </main>
</div>
{% endblock %}
