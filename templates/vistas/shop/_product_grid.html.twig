{% set viewBase = viewBase|default('vistas/shop') %}
<!-- Grid Header -->
<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-5 gap-3" x-init="totalItems = {{ items is defined ? items|length : 0 }}">
	<div>
		<h2 class="text-lg sm:text-xl font-bold text-gray-900 tracking-tight" x-text="storeName">{{ storeName|default('YonkEros') }}</h2>
		<div class="flex items-center gap-2 mt-1">
			<span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
			<p class="text-[11px] text-gray-400 font-medium">
				Tienda verificada
				{% if dtaCtc.localidad is defined and dtaCtc.localidad is not empty %}
					<span x-show="!localidad">· {{ dtaCtc.localidad }}</span>
				{% endif %}
				<span x-show="localidad" x-cloak>· <span x-text="localidad"></span></span>
				· <span x-text="totalItems + ' piezas'"></span>
			</p>
		</div>
	</div>
	
	<div class="flex items-center gap-3">
		<!-- View toggle -->
		<div class="flex bg-gray-100 rounded-lg p-0.5">
			<button @click="viewMode = 'grid'" 
					:class="viewMode === 'grid' ? 'bg-white shadow-sm text-gray-700' : 'text-gray-400 hover:text-gray-500'"
					class="p-1.5 rounded-md transition-all">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
			</button>
			<button @click="viewMode = 'list'" 
					:class="viewMode === 'list' ? 'bg-white shadow-sm text-gray-700' : 'text-gray-400 hover:text-gray-500'"
					class="p-1.5 rounded-md transition-all">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
			</button>
		</div>

		<!-- Mobile filter button -->
		<button @click="showFilters = true" class="lg:hidden flex items-center gap-1.5 px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-xs font-medium text-gray-600 hover:border-gray-300 transition-colors">
			<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
			Filtrar
		</button>
	</div>
</div>

<!-- Product Grid -->
{% if items|length > 0 or missingIds|default('') is empty %}
<div :class="viewMode === 'grid' ? 'grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 sm:gap-4' : 'flex flex-col gap-2'">
	{% for item in items %}
        <template x-if="viewMode === 'grid'">
		    {% include viewBase ~ '/_product_card.html.twig' %}
        </template>
        <template x-if="viewMode === 'list'">
		    {% include viewBase ~ '/_product_card_list.html.twig' %}
        </template>
	{% endfor %}
	
	{% if items|length == 0 %}
		<div class="col-span-full py-16 flex flex-col items-center justify-center">
			<div class="w-14 h-14 bg-gray-100 rounded-full flex items-center justify-center text-gray-300 mb-3">
				<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
			</div>
			<h3 class="text-sm font-semibold text-gray-700 mb-1">Sin resultados</h3>
			<p class="text-xs text-gray-400">Prueba con otros filtros o términos.</p>
		</div>
	{% endif %}
</div>
{% endif %}

<!-- Pagination -->
{% if pagesCount > 1 %}
<div class="mt-8 flex justify-center">
	<nav class="inline-flex items-center gap-1">
		{% for p in 1..pagesCount %}
			<a href="?page={{ p }}" 
				@click.prevent="applyFilter({page: {{ p }}})" 
				class="w-8 h-8 flex items-center justify-center rounded-lg text-xs font-medium transition-all {{ p == currentPage ? 'bg-dark text-white' : 'text-gray-400 hover:text-gray-600 hover:bg-gray-100' }}">
				{{ p }}
			</a>
		{% endfor %}
	</nav>
</div>
{% endif %}

<div class="hidden" x-init="$nextTick(() => fetchMissingMeli('{{ missingIds|default('') }}'))"></div>
