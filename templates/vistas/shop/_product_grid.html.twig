<!-- Grid Header -->
<div class="flex items-center justify-between">
    <div>
        <h2 class="text-2xl font-black text-[#103928] tracking-tight">Todas las Piezas</h2>
        <p class="text-[15px] text-[#103928]/60 font-bold mt-1">Mostrando {{ items|length }} resultados</p>
    </div>
    <div class="flex items-center gap-2">
        <span class="text-xs text-[#103928] font-black uppercase tracking-wider">Ordenar por:</span>
        <select class="bg-white border-slate-200 rounded-xl px-4 py-2 text-xs font-black text-[#103928] outline-none focus:ring-2 focus:ring-primary/10 transition-all cursor-pointer">
            <option>Más recientes</option>
            <option>Precio: Menor a Mayor</option>
            <option>Precio: Mayor a Menor</option>
        </select>
    </div>
</div>

<!-- The Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    {% for item in items %}
        {% include 'vistas/shop/_product_card.html.twig' %}
    {% endfor %}
    
    {% if items|length == 0 %}
        <div class="col-span-full py-20 flex flex-col items-center justify-center bg-white rounded-[3rem] border border-dashed border-slate-200">
            <div class="w-20 h-20 bg-[#f0f7f4] rounded-full flex items-center justify-center text-[#25d366] mb-4">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 9.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="text-lg font-black text-[#103928]">No se encontraron piezas</h3>
            <p class="text-sm text-slate-500">Prueba con otros filtros o términos de búsqueda.</p>
        </div>
    {% endif %}
</div>

<!-- Pagination -->
{% if pagesCount > 1 %}
<div class="mt-12 flex justify-center">
    <nav class="flex items-center gap-2 bg-white p-2 rounded-2xl shadow-sm border border-slate-200">
        {% for p in 1..pagesCount %}
            <button @click="applyFilter({page: {{ p }}})" 
                    class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-bold transition-all {{ p == currentPage ? 'bg-[#25d366] text-white shadow-lg shadow-[#25d366]/20' : 'text-slate-400 hover:bg-white hover:shadow-sm' }}">
                {{ p }}
            </button>
        {% endfor %}
    </nav>
</div>
{% endif %}
