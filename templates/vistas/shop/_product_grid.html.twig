<!-- Grid Header -->
<div class="flex flex-col sm:flex-row items-start sm:items-end justify-between mb-8 gap-4" x-init="totalItems = {{ items is defined ? items|length : 0 }}">
	<div>
		<h2 class="text-2xl sm:text-4xl font-black text-[#103928] tracking-tight uppercase leading-none" x-text="storeName">{{ storeName|default('YonkEros - Autopartes Online') }}</h2>
		<div class="flex items-center gap-2 mt-2 sm:mt-3">
			<span class="w-2.5 h-2.5 rounded-full bg-[#25d366] animate-pulse shadow-sm shadow-[#25d366]/50"></span>
			<p class="text-xs text-[#103928]/60 font-black uppercase tracking-widest">
				Tienda Verificada 
				{% if dtaCtc.localidad is defined and dtaCtc.localidad is not empty %}
					<span x-show="!localidad">&bull; <span class="text-[#103928]/80">{{ dtaCtc.localidad }}</span></span>
				{% endif %}
				<span x-show="localidad" x-cloak>&bull; <span class="text-[#103928]/80" x-text="localidad"></span></span>
			</p>
		</div>
	</div>
	
	<div class="flex items-center gap-2">
		<span class="text-[10px] sm:text-xs text-[#103928] font-black uppercase tracking-wider">Ordenar por:</span>
		<select class="bg-white border-slate-200 rounded-xl px-4 py-2 text-xs font-black text-[#103928] outline-none focus:ring-2 focus:ring-[#25d366]/10 transition-all cursor-pointer shadow-sm">
			<option>Más recientes</option>
			<option>Precio: Menor a Mayor</option>
			<option>Precio: Mayor a Menor</option>
		</select>
	</div>
</div>

<!-- The Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
	{% for item in items %}
		{% include 'vistas/shop/_product_card.html.twig' %}
	{% endfor %}
	
	{% if items|length == 0 %}
		<div class="col-span-full py-20 flex flex-col items-center justify-center bg-white rounded-[3rem] border border-dashed border-slate-200">
			<div class="w-20 h-20 bg-[#f0f7f4] rounded-full flex items-center justify-center text-[#25d366] mb-4">
					<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 9.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
			</div>
			<h3 class="text-lg font-black text-[#103928]">No se encontraron piezas</h3>
			<p class="text-sm text-slate-500">Prueba con otros filtros o términos de búsqueda.</p>
		</div>
	{% endif %}
</div>

<!-- Pagination -->
{% if pagesCount > 1 %}
<div class="mt-12 flex justify-center">
	<nav class="flex items-center gap-2 bg-white p-2 rounded-2xl shadow-sm border border-slate-200">
		{% for p in 1..pagesCount %}
			<a href="?page={{ p }}" 
				@click.prevent="applyFilter({page: {{ p }}})" 
				class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-bold transition-all {{ p == currentPage ? 'bg-[#25d366] text-white shadow-lg shadow-[#25d366]/20' : 'text-slate-400 hover:bg-slate-50 hover:shadow-sm' }}">
				{{ p }}
			</a>
		{% endfor %}
	</nav>
</div>
{% endif %}
