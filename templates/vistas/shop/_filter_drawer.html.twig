<div x-data="{ 
	filters: [], 
	loading: true,
	async fetchFilters() {
		try {
			const res = await fetch('{{ path('app_shop_filters', {slug: slug}) }}?t=' + Date.now());
			this.filters = await res.json();
		} finally {
			this.loading = false;
		}
	}
}" x-init="fetchFilters()" class="space-y-1">

<div class="flex items-center justify-between px-1 mb-3">
	<span class="text-[11px] text-gray-400 font-medium">Selecciona una marca</span>
	<button @click="applyFilter({mk: '', md: '', page: 1})" 
					class="text-[10px] font-medium text-red-500 hover:text-red-600 px-2 py-1 rounded hover:bg-red-50 transition-colors">
			Limpiar
	</button>
</div>

<!-- Loading skeleton -->
<template x-if="loading">
	<div class="space-y-2 px-1">
		<div class="h-9 bg-gray-100 rounded-lg animate-pulse"></div>
		<div class="h-9 bg-gray-100 rounded-lg animate-pulse w-5/6"></div>
		<div class="h-9 bg-gray-100 rounded-lg animate-pulse w-4/6"></div>
	</div>
</template>

<!-- Brand list -->
<template x-for="brand in filters" :key="brand.id">
	<div x-data="{ open: false }">
		<button @click="open = !open" 
						class="w-full flex items-center justify-between py-2 px-3 rounded-lg transition-colors text-left"
						:class="open ? 'bg-primary/5 text-gray-900' : 'text-gray-600 hover:bg-gray-50'">
			<div class="flex items-center gap-2">
				<svg class="w-3 h-3 transition-transform duration-200 flex-shrink-0" 
							:class="open ? 'rotate-90 text-primary' : 'text-gray-300'"
							fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
				</svg>
				<span class="text-xs font-medium" x-text="brand.name"></span>
			</div>
			<span class="text-[10px] font-medium text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded" x-text="brand.count"></span>
		</button>

		<div x-show="open" x-collapse class="ml-5 mt-0.5 space-y-0.5 border-l border-gray-100 pl-3">
			<button @click="applyFilter({mk: brand.id, md: '', page: 1})" 
						class="w-full text-left py-1.5 px-2 text-[11px] font-medium text-gray-400 hover:text-primary rounded transition-colors">
				Ver todo <span x-text="brand.name"></span>
			</button>
			
			<template x-for="model in brand.models" :key="model.id">
				<button @click="applyFilter({mk: brand.id, md: model.id, page: 1})" 
						class="w-full text-left py-1.5 px-2 text-[11px] text-gray-500 hover:text-primary rounded transition-colors"
						x-text="model.name">
				</button>
			</template>
		</div>
	</div>
</template>

</div>
