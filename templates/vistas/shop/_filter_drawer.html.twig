<div x-data="{ 
	filters: [], 
	loading: true,
	async fetchFilters() {
		try {
			const res = await fetch('{{ path('app_shop_filters', {slug: slug}) }}?t=' + Date.now());
			this.filters = await res.json();
		} finally {
			this.loading = false;
		}
	}
}" x-init="fetchFilters()" class="space-y-4">

<div class="space-y-4">
	<div class="space-y-2">
		<div class="space-y-1">
			<template x-if="loading">
				<div class="space-y-2.5 animate-pulse px-1">
					<div class="h-9 bg-slate-100 rounded-lg"></div>
					<div class="h-9 bg-slate-100 rounded-lg"></div>
					<div class="h-9 bg-slate-100 rounded-lg w-2/3"></div>
				</div>
			</template>

			<template x-for="brand in filters" :key="brand.id">
				<div class="group" x-data="{ open: false }">

					<button @click="open = !open" 
									class="w-full flex items-center justify-between py-2.5 px-3 rounded-lg transition-all hover:bg-slate-50 border border-transparent"
									:class="open ? 'bg-white text-[#0e7045] border-slate-200 shadow-sm font-bold' : 'text-slate-600'">
						<div class="flex items-center gap-2">
								<svg class="w-3 h-3 transition-transform duration-300" 
											:class="open ? 'rotate-90 text-[#0e7045]' : 'text-slate-400'"
											fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
								</svg>
								<span class="text-[13px] font-semibold uppercase tracking-wider" x-text="brand.name"></span>
						</div>
						<span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-slate-100 text-slate-500 transition-colors" 
							:class="open ? 'bg-[#0e7045]/10 text-[#0e7045]' : 'bg-slate-100 text-slate-500'"
							x-text="brand.count"></span>
					</button>

					<div x-show="open" x-collapse class="ml-6 mt-1.5 space-y-1 border-l border-slate-200 pl-3">
						<!-- Opción para ver TODA la marca -->
						<button @click="applyFilter({mk: brand.id, md: '', page: 1})" 
									class="w-full text-left py-1.5 px-2.5 text-[13px] font-semibold text-slate-400 hover:text-[#0e7045] transition-colors uppercase tracking-wider">
							Ver todo <span x-text="brand.name"></span>
						</button>
						
						<template x-for="model in brand.models" :key="model.id">
							<button @click="applyFilter({mk: brand.id, md: model.id, page: 1})" 
									class="w-full text-left py-1.5 px-2.5 text-[13px] font-medium text-slate-500 hover:text-[#0e7045] transition-colors uppercase tracking-wider"
									x-text="model.name">
							</button>
						</template>
					</div>
				</div>
			</template>
		</div>
	</div>
</div>

</div>
