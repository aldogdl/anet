<div x-show="showCart" class="fixed inset-0 z-[120] overflow-y-auto" x-cloak>
    <div class="fixed inset-0 bg-[#0b141a]/80 backdrop-blur-xl transition-opacity" @click="showCart = false"></div>

    <div class="flex min-h-full items-center justify-center p-4 md:p-12">
        <!-- Main Modal Container: A4 Style Width -->
        <div class="relative w-full max-w-4xl bg-[#f8fafc] rounded-[2rem] shadow-[0_32px_64px_-16px_rgba(0,0,0,0.5)] overflow-hidden transform transition-all border border-white/20"
             x-transition:enter="ease-out duration-500"
             x-transition:enter-start="opacity-0 translate-y-12 scale-95"
             x-transition:enter-end="opacity-100 translate-y-0 scale-100">
            
            <!-- Close Button -->
            <button @click="showCart = false" class="absolute top-6 right-6 p-2 text-slate-400 hover:text-slate-900 transition-all z-20 group">
                <svg class="w-6 h-6 group-hover:rotate-90 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>

            <!-- Decorative Element -->
            <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-emerald-400 via-[#25d366] to-emerald-400"></div>

            <div class="p-6 md:p-10">
                
                <!-- HEADER SECTION -->
                <div class="flex flex-col md:flex-row justify-between items-start gap-8 mb-4 border-b border-slate-200 pb-6">
                    <div class="flex items-center gap-6">
                        <div class="relative">
                            <div class="absolute inset-0 bg-[#25d366]/10 blur-xl rounded-full"></div>
                            {% if dtaCtc.logo is defined and dtaCtc.logo is not empty %}
                                <img src="{{ app.request.getSchemeAndHttpHost() }}{{ app.request.getBasePath() }}/ctc_logo/{{ dtaCtc.logo }}" class="relative w-32 h-32 object-contain rounded-xl bg-white shadow-xl border border-slate-100 p-2" alt="Logo">
                            {% else %}
                                <div class="relative w-32 h-32 bg-[#0b141a] rounded-xl flex items-center justify-center text-[#25d366] shadow-xl border border-slate-800">
                                    <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                </div>
                            {% endif %}
                        </div>
                        <div class="space-y-1">
                            <h2 class="text-3xl font-black text-[#0b141a] tracking-tight leading-none" x-text="storeName"></h2>
                            <div class="flex flex-col gap-0.5">
                                <p class="text-slate-700 font-bold text-base flex items-center gap-2">
                                    <svg class="w-4 h-4 text-[#25d366]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                    {{ contactPhone }}
                                </p>
                                <p class="text-slate-500 font-black text-[11px] uppercase tracking-widest ml-6" x-text="localidad"></p>
                            </div>
                        </div>
                    </div>

                    <div class="w-full md:w-48 bg-white rounded-xl border border-slate-300 overflow-hidden shadow-md">
                        <div class="bg-[#0b141a] py-1.5 px-4 text-center">
                            <span class="text-white text-[9px] font-black tracking-[0.2em] uppercase">FECHA EMISIÓN</span>
                        </div>
                        <div class="flex divide-x divide-slate-200 bg-white">
                            <div class="flex-1 py-2 text-center">
                                <span class="text-slate-500 text-[8px] font-black block uppercase">Día</span>
                                <span class="text-lg font-black text-[#0b141a]" x-text="new Date().getDate().toString().padStart(2, '0')"></span>
                            </div>
                            <div class="flex-1 py-2 text-center">
                                <span class="text-slate-500 text-[8px] font-black block uppercase">Mes</span>
                                <span class="text-lg font-black text-[#0b141a]" x-text="(new Date().getMonth() + 1).toString().padStart(2, '0')"></span>
                            </div>
                            <div class="flex-1 py-2 text-center">
                                <span class="text-slate-500 text-[8px] font-black block uppercase">Año</span>
                                <span class="text-lg font-black text-[#0b141a]" x-text="new Date().getFullYear()"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- INFO BAR -->
                <div class="flex justify-between items-center mb-4 px-1">
                    <div class="flex items-center gap-4">
                        <h3 class="text-base font-black text-[#0b141a] uppercase tracking-wider flex items-center gap-2">
                            <span class="w-1 h-4 bg-[#25d366] rounded-full"></span>
                            Detalle de Cotización
                        </h3>
                        <button @click="if(confirm('¿Seguro que deseas vaciar todo el carrito?')) { cartItems = {}; addToast('Carrito vaciado'); }" 
                                class="text-[9px] font-black text-red-500 hover:text-red-600 uppercase tracking-widest flex items-center gap-1.5 px-3 py-1 bg-red-50 rounded-full border border-red-100 transition-all active:scale-95">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            Vaciar Todo
                        </button>
                    </div>
                    <p class="text-[11px] text-slate-600 font-bold hidden sm:block">
                        ID Tienda: <span class="text-[#0b141a] font-black">yonkeros.com/shop/{{ slug }}</span>
                    </p>
                </div>

                <!-- PRODUCT LIST -->
                <div class="bg-white rounded-2xl border border-slate-300 shadow-lg overflow-hidden mb-6">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 border-b border-slate-300">
                                <th class="py-3 px-5 text-[9px] font-black text-slate-600 uppercase tracking-widest">Descripción</th>
                                <th class="py-3 px-3 text-[9px] font-black text-slate-600 uppercase tracking-widest text-center w-24">ID</th>
                                <th class="py-3 px-5 text-[9px] font-black text-slate-600 uppercase tracking-widest text-right w-32">Precio</th>
                                <th class="py-3 px-2 text-center w-12"></th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200">
                            <template x-for="(item, id) in cartItems" :key="id">
                                <tr class="hover:bg-slate-50/50 group/row">
                                    <td class="py-2.5 px-5">
                                        <div class="flex items-center gap-4">
                                            <img :src="item.thumb" class="w-12 h-12 rounded-lg object-cover bg-slate-100 border border-slate-300 shadow-sm" alt="Producto">
                                            <span class="text-sm font-bold text-slate-800 leading-tight" x-text="item.title"></span>
                                        </div>
                                    </td>
                                    <td class="py-2.5 px-3 text-center">
                                        <span class="text-[10px] font-mono font-bold text-slate-700" x-text="item.id || item.idSrc"></span>
                                    </td>
                                    <td class="py-2.5 px-5 text-right">
                                        <span class="text-base font-black text-[#0b141a]" x-text="'$' + parseFloat(item.price).toLocaleString()"></span>
                                    </td>
                                    <td class="py-2.5 px-2 text-center">
                                        <button @click="promptRemove(id)" class="p-1.5 text-slate-300 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all active:scale-90">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                    
                    <!-- Inner Summary Area -->
                    <div class="bg-slate-50 p-4 border-t border-slate-300 flex justify-between items-center">
                        <div class="text-left">
                            <p class="text-[10px] text-slate-600 font-bold uppercase tracking-widest">Condiciones</p>
                            <p class="text-[11px] text-red-600 font-black">Los Precios pueden variar sin previo aviso, Costo sin I.V.A ni envío.</p>
                        </div>
                        <div class="text-right">
                            <span class="text-slate-600 text-[10px] font-black uppercase tracking-wider block mb-0.5">Total Estimado</span>
                            <div class="text-3xl font-black text-[#0b141a] tabular-nums" x-text="'$' + cartTotal.toLocaleString()"></div>
                        </div>
                    </div>
                </div>

                <!-- ACTION SECTION: Instructions & QR -->
                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-stretch mb-4">
                    
                    <!-- Instructions (Left) -->
                    <div class="md:col-span-8 bg-white p-5 rounded-2xl border border-slate-300 shadow-lg flex flex-col">
                        <div class="space-y-4">
                            <ul class="space-y-2">
                                <li class="flex items-start gap-3 group">
                                    <span class="flex-shrink-0 w-6 h-6 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center text-[10px] font-black text-slate-500 group-hover:bg-[#25d366]/10 group-hover:text-[#25d366] group-hover:border-[#25d366] transition-all">01</span>
                                    <p class="text-slate-700 text-xs font-bold pt-1">Escanea el QR para <span class="text-[#0b141a] font-black">contacto directo</span>.</p>
                                </li>
                                <li class="flex items-start gap-3 group">
                                    <span class="flex-shrink-0 w-6 h-6 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center text-[10px] font-black text-slate-500 group-hover:bg-[#25d366]/10 group-hover:text-[#25d366] group-hover:border-[#25d366] transition-all">02</span>
                                    <p class="text-slate-700 text-xs font-bold pt-1">Presiona el cuadro del QR para <span class="text-[#0b141a] font-black">abrir WhatsApp</span>.</p>
                                </li>
                                <li class="flex items-start gap-3 group">
                                    <span class="flex-shrink-0 w-6 h-6 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center text-[10px] font-black text-slate-500 group-hover:bg-[#25d366]/10 group-hover:text-[#25d366] group-hover:border-[#25d366] transition-all">03</span>
                                    <p class="text-slate-700 text-xs font-bold pt-1">Usa el botón para <span class="text-[#0b141a] font-black">descargar tu cotización</span> PDF.</p>
                                </li>
                            </ul>
                        </div>

                        <a href="{{ path('cotizacion_pdf', {slug: slug}) }}" 
                           class="w-full bg-[#0b141a] hover:bg-[#1a2e3a] text-white font-black py-3 rounded-xl transition-all shadow-md active:scale-[0.98] flex items-center justify-center gap-2 group mt-4">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                            <span class="uppercase tracking-widest text-[10px]">Descargar Cotización PDF</span>
                        </a>
                    </div>

                    <!-- QR SECTION (Right) -->
                    <div class="md:col-span-4 flex flex-col">
                        <div class="relative group cursor-pointer h-full" @click="window.open('https://wa.me/{{ contactPhone }}?text=' + encodeURIComponent('Hola, me interesa esta cotización: ' + cartItemsTitles), '_blank')">
                            <div class="absolute -inset-1 bg-gradient-to-tr from-[#25d366] to-emerald-400 opacity-10 blur-xl rounded-full group-hover:opacity-20 transition-opacity"></div>
                            <div class="relative bg-white rounded-2xl shadow-lg border border-slate-300 h-full flex flex-col items-center justify-center p-4">
                                <div class="p-3 bg-slate-50 rounded-2xl border border-slate-100 group-hover:scale-105 transition-transform duration-500 shadow-inner">
                                    <img :src="'https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=' + encodeURIComponent('https://wa.me/{{ contactPhone }}?text=' + encodeURIComponent('Hola, me interesa esta cotización: ' + cartItemsTitles))" 
                                         class="w-32 h-32 object-contain" alt="QR WhatsApp">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
