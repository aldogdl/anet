{% import 'vistas/common/_product_helpers.html.twig' as product %}

{% set placeholder = 'https://placehold.co/600x600/f5f5f5/a3a3a3?text=Sin+Foto' %}

{% set extras = item.extras %}
{% set mainImg = product.cardImg(item) %}
{% set firstPic = (extras.pictures|default([]))|first %}
{% set imgBig = product.imgUrl(item, firstPic) %}
{% set modalData = {
    id: item.id,
    title: item.title,
    price: item.price,
    thumb: mainImg,
    imgBig: imgBig,
    detalles: item.detalles|default(''),
    sku: item.iku|default('N/A'),
    brand: item.mrkId,
    model: item.mdlId,
    pieza: item.pieza|default(''),
    lado: item.lado|default(''),
    poss: item.poss|default(''),
    anioInicio: item.anioInicio|default(0),
    anioFin: item.anioFin|default(9999),
    pictures: extras.pictures|default([]),
    pathImg: extras.pathImg|default(''),
    mk: extras.mk|default(''),
    md: extras.md|default(''),
    numPart: extras.numPart|default(''),
    localidad: extras.localidad|default(''),
    idSrc: extras.idSrc|default(''),
    linkSr: extras.linkSr|default(''),
    fuente: extras.fuente|default(''),
    calif: extras.calif|default(0)
}|json_encode %}
{% set cleanSlug = product.cleanSlug(item.title) %}
{% set cleanTitle = product.cleanTitle(item.title) %}

{% set isMeli = isMeli|default(false) %}
{% set safeId = product.safeId(item) %}
{% set detailUrl = product.detailUrl(item, isMeli) %}

<div class="group bg-white rounded-xl border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all duration-300 flex flex-col h-full overflow-hidden"
	 {{ isMeli ? '' : ('data-item="' ~ modalData|e('html_attr') ~ '" @click.prevent="openModal(JSON.parse($event.currentTarget.getAttribute(\'data-item\')))"')|raw }}>

	<!-- Image -->
	<a href="{{ detailUrl }}" {{ isMeli ? 'target="_blank"' : '' }} 
	   class="block relative aspect-[4/3] bg-gray-50 overflow-hidden" 
       {{ isMeli ? '' : ('data-item="' ~ modalData|e('html_attr') ~ '" @click.prevent="openModal(JSON.parse($event.currentTarget.getAttribute(\'data-item\')))"')|raw }}>
		
		<img src="{{ mainImg }}" 
			 onerror="this.src='{{ placeholder }}'"
			 class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500 ease-out" 
			 alt="{{ item.title }}" loading="lazy">

		{% if item.isActive %}
		<div class="absolute top-2.5 left-2.5 flex items-center gap-1 bg-white/90 backdrop-blur-sm px-2 py-1 rounded-md">
			<span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
			<span class="text-[10px] font-semibold text-gray-600">En stock</span>
		</div>
		{% endif %}

		{% if isMeli %}
		<div class="absolute top-2.5 right-2.5 bg-[#ffe600] text-[#2d3277] text-[9px] font-bold px-2 py-0.5 rounded">ML</div>
		{% endif %}
	</a>

	<!-- Info -->
	<div class="p-3.5 sm:p-4 flex-1 flex flex-col">
		<a href="{{ detailUrl }}" {{ isMeli ? 'target="_blank"' : '' }}
		   class="text-[13px] font-medium text-gray-800 leading-snug line-clamp-2 hover:text-primary transition-colors min-h-[2.5rem]"
		   {{ isMeli ? '' : ('data-item="' ~ modalData|e('html_attr') ~ '" @click.prevent="openModal(JSON.parse($event.currentTarget.getAttribute(\'data-item\')))"')|raw }}>
			{{ item.title }}
		</a>

		<div class="mt-auto pt-3 flex items-end justify-between gap-2">
			<div>
				<span class="text-[9px] text-white bg-slate-800 px-1.5 py-0.5 rounded font-medium block w-fit mb-1 tracking-wider uppercase">ID: <span class="font-black">{{ item.id }}</span></span>
				<span class="text-lg font-bold text-gray-900 tracking-tight">${{ item.price|number_format(2, '.', ',') }}</span>
			</div>

			<div class="flex items-center gap-1.5">
				{% if isMeli %}
					<a href="{{ detailUrl }}" target="_blank" class="w-8 h-8 bg-[#ffe600] text-[#2d3277] rounded-lg flex items-center justify-center hover:bg-yellow-300 active:scale-95 transition-all">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
					</a>
				{% else %}
					<template x-if="!({{ safeId }} in cartItems)">
						<button @click.stop="addToCart({{ safeId }})" 
									class="w-8 h-8 bg-primary text-dark rounded-lg flex items-center justify-center hover:bg-emerald-400 active:scale-95 transition-all">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
						</button>
					</template>
					<template x-if="{{ safeId }} in cartItems">
						<button @click.stop="promptRemove({{ safeId }})" 
									class="w-8 h-8 bg-primary/15 text-primary rounded-lg flex items-center justify-center hover:bg-primary/25 active:scale-95 transition-all">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
						</button>
					</template>
				{% endif %}
			</div>
		</div>
	</div>
</div>
