{% set extras = item.extras %}
{% set mainImg = extras.pathImg is defined and extras.pictures is defined and extras.pictures|length > 0 
    ? extras.pathImg ~ '/' ~ extras.pictures[0] 
    : item.thumb %}
{% set placeholder = 'https://placehold.co/600x600/f8fafc/64748b?text=Sin+Imagen' %}
{% set modalData = {
    id: item.id,
    title: item.title,
    price: item.price,
    thumb: mainImg,
    imgBig: mainImg,
    detalles: item.detalles|default('Sin detalles adicionales.'),
    sku: item.iku|default('N/A'),
    brand: item.mrkId,
    model: item.mdlId,
    pictures: extras.pictures|default([]),
    pathImg: extras.pathImg|default('')
}|json_encode %}
{% set cleanSlug = item.title|lower|replace({' ': '-', '/': '-', '\\': '-'})|url_encode|slice(0, 50) %}

{% set isMeli = isMeli|default(false) %}
{% set safeId = item.id ?: 0 %}
{% set detailUrl = isMeli and extras.permalink is defined ? extras.permalink : path('app_product_detail', { id: safeId, slug: cleanSlug }) %}

<div class="group bg-white border border-slate-200 rounded-[2.5rem] overflow-hidden hover:border-[#25d366]/40 transition-all duration-500 flex flex-col shadow-sm hover:shadow-2xl hover:shadow-slate-200/60 relative">
	<!-- Top Accent Line -->
	<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r {{ isMeli ? 'from-transparent via-[#ffe600] to-transparent' : 'from-transparent via-[#103928]/20 to-transparent' }}"></div>
	<!-- Image Area (SEO Friendly Link) -->
	<a href="{{ detailUrl }}" {{ isMeli ? 'target="_blank"' : '' }} class="block relative aspect-[16/10] overflow-hidden bg-[#f8fafc] cursor-pointer" {{ isMeli ? '' : ('data-item="' ~ modalData|e('html_attr') ~ '" @click.prevent="openModal(JSON.parse($event.currentTarget.getAttribute(\'data-item\')))"')|raw }}>

	<img src="{{ mainImg }}" 
		onerror="this.src='{{ placeholder }}'"
		class="w-full h-full object-cover object-center p-3 rounded-[2rem] group-hover:scale-105 transition-transform duration-700" 
		alt="{{ item.title }}"
	>
        
	<!-- Status Badge -->
	{% if item.isActive %}
		<div class="absolute top-5 left-5 flex items-center gap-1.5 bg-white px-3 py-1.5 rounded-full border border-slate-100 shadow-sm">
			<span class="w-2 h-2 rounded-full bg-[#25d366] animate-pulse"></span>
			<span class="text-[9px] font-black text-[#103928] uppercase tracking-widest">Disponible</span>
		</div>
	{% endif %}
	</a>

<!-- Info Area -->
<div class="p-7 flex-1 flex flex-col">

	<div class="flex-1">
		<a href="{{ detailUrl }}" {{ isMeli ? 'target="_blank"' : '' }}
		   class="block text-[15px] font-bold text-[#103928] line-clamp-3 leading-tight group-hover:text-[#25d366] transition-colors cursor-pointer min-h-[3.75rem]" 
		   {{ isMeli ? '' : ('data-item="' ~ modalData|e('html_attr') ~ '" @click.prevent="openModal(JSON.parse($event.currentTarget.getAttribute(\'data-item\')))"')|raw }}>
			{{ item.title }}
		</a>
	</div>

	<div class="mt-1 pt-6 border-t border-slate-50 flex items-center justify-between gap-4">
		<div class="flex flex-col">
			<span class="text-[10px] text-[#103928]/50 font-black uppercase tracking-widest mb-1">Precio Neto</span>
			<span class="text-2xl font-black text-[#103928] italic">
				${{ item.price|number_format(2, '.', ',') }}
			</span>
		</div>
		
		{% if isMeli %}
			<a href="{{ detailUrl }}" target="_blank" class="px-4 py-2 bg-[#ffe600] text-[#2d3277] font-black text-[10px] uppercase tracking-widest rounded-xl shadow-lg shadow-[#ffe600]/20 hover:bg-yellow-400 active:scale-95 transition-all flex-shrink-0 flex items-center justify-center">
				Ver en Meli
			</a>
		{% else %}
			<template x-if="!cartItems.includes({{ safeId }})">
				<button @click="addToCart({{ safeId }})" 
							class="p-3 bg-[#25d366] text-white hover:bg-emerald-400 rounded-xl transition-all shadow-lg shadow-[#25d366]/20 active:scale-90 flex-shrink-0">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
				</button>
			</template>
			<template x-if="cartItems.includes({{ safeId }})">
				<button @click="promptRemove({{ safeId }})" 
							class="p-3 bg-[#25d366]/20 text-[#25d366] hover:bg-[#25d366]/30 rounded-xl transition-all shadow-sm active:scale-90 flex-shrink-0">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
				</button>
			</template>
		{% endif %}
	</div>
	<div class="flex items-center gap-2 mt-1">
		<span class="text-[12px] bg-slate-100 text-slate-500 font-black px-2 py-0.5 rounded tracking-widest">{{ item.iku|default('N/A') }}/{{ item.id }}</span>
	</div>
</div>

</div>
