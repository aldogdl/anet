{% set extras = item.extras %}
{% set mainImg = extras.pathImg is defined and extras.pictures is defined and extras.pictures|length > 0 
    ? extras.pathImg ~ '/' ~ extras.pictures[0] 
    : item.thumb %}
{% set title = extras.fuente is defined and extras.fuente is not empty ? extras.fuente : item.title %}
{% set placeholder = 'https://placehold.co/600x600/f8fafc/64748b?text=Sin+Imagen' %}

<div class="group bg-white border border-slate-200 rounded-[2.5rem] overflow-hidden hover:border-[#25d366]/40 transition-all duration-500 flex flex-col shadow-sm hover:shadow-2xl hover:shadow-slate-200/60 relative">
    <!-- Top Accent Line -->
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#103928]/20 to-transparent"></div>
    <!-- Image Area -->
    <div class="relative aspect-[16/10] overflow-hidden bg-[#f8fafc] cursor-pointer" @click="openModal({{ {
        id: item.id,
        title: title,
        price: item.price,
        thumb: mainImg,
        imgBig: mainImg,
        detalles: item.detalles|default('Sin detalles adicionales.'),
        sku: item.iku|default('N/A'),
        brand: item.mrkId,
        model: item.mdlId,
        pictures: extras.pictures|default([]),
        pathImg: extras.pathImg|default('')
    }|json_encode|e('html_attr') }})">
        <img src="{{ mainImg }}" 
             onerror="this.src='{{ placeholder }}'"
             class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-700" 
             alt="{{ title }}">
        
        <!-- Status Badge -->
        {% if item.isActive %}
            <div class="absolute top-5 left-5 flex items-center gap-1.5 bg-white px-3 py-1.5 rounded-full border border-slate-100 shadow-sm">
                <span class="w-2 h-2 rounded-full bg-[#25d366] animate-pulse"></span>
                <span class="text-[9px] font-black text-[#103928] uppercase tracking-widest">Disponible</span>
            </div>
        {% endif %}
    </div>

    <!-- Info Area -->
    <div class="p-7 flex-1 flex flex-col">
        <div class="flex-1">
            <div class="flex items-center gap-2 mb-3">
                <span class="text-[9px] bg-slate-100 text-slate-500 font-black px-2 py-0.5 rounded tracking-widest uppercase">REF: {{ item.iku|default('N/A') }}</span>
            </div>
            <h3 class="text-[15px] font-bold text-[#103928] line-clamp-2 leading-tight group-hover:text-[#25d366] transition-colors cursor-pointer min-h-[2.5rem]" 
                @click="openModal(...)">
                {{ title }}
            </h3>
        </div>

        <div class="mt-6 pt-6 border-t border-slate-50 flex items-center justify-between gap-4">
            <div class="flex flex-col">
                <span class="text-[10px] text-[#103928]/50 font-black uppercase tracking-widest mb-1">Precio Neto</span>
                <span class="text-2xl font-black text-[#103928] italic">
                    ${{ item.price|number_format(2, '.', ',') }}
                </span>
            </div>
            
            <button @click="addToCart({{ item.id }})" 
                    class="p-4 bg-[#25d366] text-white hover:bg-emerald-400 rounded-2xl transition-all shadow-lg shadow-[#25d366]/20 active:scale-90 flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
            </button>
        </div>
    </div>
</div>
