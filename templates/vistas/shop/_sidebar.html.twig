<div class="bg-white border border-slate-200/80 overflow-hidden sticky top-20 shadow-sm flex flex-col rounded-xl" style="height: calc(100vh - 100px);">
	<!-- Sidebar Header -->
	<div class="px-5 py-4 border-b border-slate-100 bg-slate-50/50">
			<div class="flex items-center justify-between">
				<h3 class="text-xs font-bold text-slate-700 uppercase tracking-wider flex items-center gap-2">
						<svg class="w-3.5 h-3.5 text-[#0e7045]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
						Filtrar Catálogo
				</h3>
				
				<!-- Botón Limpiar Global Invertido (Más llamativo) -->
				<button @click="applyFilter({mk: '', md: '', page: 1})" 
								x-show="currentFilters.mk !== '' || currentFilters.md !== ''"
								x-cloak x-transition.opacity
								class="text-[9px] font-bold bg-red-500 hover:bg-red-600 text-white px-3 py-1.5 rounded-md transition-all uppercase tracking-wider shadow-sm hover:shadow active:scale-95 border-none">
						Limpiar
				</button>
			</div>
			<p class="text-[10px] font-semibold text-slate-400 uppercase tracking-wider mt-1.5" x-text="`Mostrando ${totalItems} resultados`"></p>
	</div>

	<!-- Filters Content con Scroll Interno -->
	<div class="p-4 space-y-4 overflow-y-auto flex-1">
		<!-- Filtros de Marcas y Modelos -->
		<div class="space-y-3">
			
			<!-- Vista Móvil: Botón que abre el drawer -->
			<div class="lg:hidden">
				<button @click="showFilters = true" 
							class="w-full flex items-center justify-between py-3 px-4 bg-slate-900 text-white rounded-xl hover:bg-slate-800 transition-all shadow-sm active:scale-95 group relative">
					<div class="flex items-center gap-3">
							<svg class="w-4 h-4 text-[#0e7045]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
							<span class="text-xs font-semibold uppercase tracking-wider">Marcas y Modelos</span>
					</div>
					<svg class="w-4 h-4 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
					
					<!-- Indicador de filtro activo -->
					<span x-show="currentFilters.mk !== '' || currentFilters.md !== ''" class="absolute -top-1 -right-1 flex h-2.5 w-2.5" x-cloak>
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500"></span>
					</span>
				</button>
			</div>

			<!-- Vista Desktop: Lista de marcas presente (inline) -->
			<div class="hidden lg:block">
				{% include viewBase ~ '/_filter_drawer.html.twig' %}
			</div>
		</div>
	</div>
</div>
