<div class="bg-white border border-slate-200 overflow-hidden sticky top-28 shadow-xl shadow-slate-200/60 flex flex-col pt-16" style="border-radius: 1.3rem;">
	<!-- Sidebar Header -->
	<div class="px-5 pb-4 pt-5 border-b border-slate-300 border-l-4 border-[#25d366]" style="background-color: #e2e8f0;">
			<div class="flex items-center justify-between">
				<h3 class="text-[11px] font-black text-black uppercase tracking-widest flex items-center gap-2">
						<svg class="w-4 h-4 text-[#25d366]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
						Filtrar Catálogo
				</h3>
				
				<!-- Botón Limpiar Global -->
				<button @click="applyFilter({mk: '', md: '', page: 1})" 
								x-show="currentFilters.mk !== '' || currentFilters.md !== ''"
								x-cloak x-transition.opacity
								class="text-[9px] font-black bg-red-500 text-white hover:bg-red-600 px-3 py-1.5 rounded-full transition-all uppercase tracking-widest shadow-lg shadow-red-500/20 border-none">
						Limpiar
				</button>
			</div>
			<p class="text-[10px] font-bold text-slate-600 uppercase tracking-widest mt-1 ml-0.5" x-text="`Mostrando ${totalItems} resultados`"></p>
	</div>

	<!-- Filters Content con Scroll Interno -->
	<div class="p-5 space-y-5 overflow-y-auto" style="max-height: 350px;">
		<!-- Filtros de Marcas y Modelos -->
		<div class="space-y-3">
			
			<!-- Vista Móvil: Botón que abre el drawer -->
			<div class="lg:hidden">
				<button @click="showFilters = true" 
							class="w-full flex items-center justify-between py-4 px-4 bg-[#0b141a] text-white rounded-2xl hover:bg-[#111b21] transition-all shadow-lg shadow-black/10 active:scale-95 group relative">
					<div class="flex items-center gap-3">
							<svg class="w-5 h-5 text-[#25d366] group-hover:rotate-180 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
							<span class="text-xs font-black uppercase tracking-widest">Marcas y Modelos</span>
					</div>
					<svg class="w-4 h-4 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
					
					<!-- Indicador de filtro activo -->
					<span x-show="currentFilters.mk !== '' || currentFilters.md !== ''" class="absolute -top-1 -right-1 flex h-3 w-3" x-cloak>
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
					</span>
				</button>
			</div>

			<!-- Vista Desktop: Lista de marcas presente (inline) -->
			<div class="hidden lg:block">
				{% include viewBase ~ '/_filter_drawer.html.twig' %}
			</div>
		</div>
	</div>
</div>
