{% import 'vistas/common/_product_helpers.html.twig' as product %}

{% set extras = item.extras %}
{% set mainImg = product.cardImg(item) %}
{% set firstPic = (extras.pictures|default([]))|first %}
{% set imgBig = product.imgUrl(item, firstPic) %}
{% set placeholder = 'https://placehold.co/600x600/f8fafc/64748b?text=Sin+Imagen' %}
{% set pTitle = product.productTitle(item) %}
{% set brandName = extras.marca|default(extras.mk|default('')) %}
{% set modelName = extras.modelo|default(extras.md|default('')) %}
{% set isMeli = isMeli|default(false) %}
{% set safeId = product.safeId(item) %}
{% set detailUrl = product.detailUrl(item, isMeli)|trim %}

{% set modalData = {
    id: item.id,
    title: pTitle,
    price: item.price,
    thumb: mainImg,
    imgBig: imgBig,
    detalles: item.detalles|default('...'),
    sku: item.iku|default('N/A'),
    brand: item.mrkId,
    model: item.mdlId,
    mk: brandName,
    md: modelName,
    pieza: item.pieza|default(''),
    numPart: extras.numPart|default(extras.idSrc|default('')),
    localidad: extras.localidad|default(''),
    anioInicio: item.anioInicio|default(0),
    anioFin: item.anioFin|default(9999),
    lado: (item.lado|default('A') == 'A') ? '' : (item.lado|lp_decode(item.pieza|default(''))),
    poss: (item.poss|default('A') == 'A') ? '' : (item.poss|lp_decode(item.pieza|default(''))),
    pictures: extras.pictures|default([]),
    pathImg: extras.pathImg|default(''),
    idSrc: extras.idSrc|default(''),
    linkSr: extras.linkSr|default(''),
    detailUrl: detailUrl
}|json_encode %}
{% set cleanSlug = product.cleanSlug(pTitle) %}
{% set cleanTitle = product.cleanTitle(pTitle) %}

<div class="group bg-white flex flex-row items-center p-2 gap-4 rounded-xl border border-slate-200 hover:border-slate-300 transition-all duration-300 relative shadow-sm hover:shadow-md"
     {{ ('data-item="' ~ modalData|e('html_attr') ~ '"')|raw }}>

	<!-- Image Area -->
	<div class="h-12 w-12 sm:h-14 w-14 flex-shrink-0 rounded-lg bg-slate-50 border border-slate-100 overflow-hidden">
		<img src="{{ mainImg }}" 
			 onerror="this.src='{{ placeholder }}'"
			 class="w-full h-full object-contain p-1" 
			 alt="{{ pTitle }}">
	</div>

	<!-- Content Area -->
	<div class="flex-1 flex flex-col sm:flex-row sm:items-center justify-between gap-4 sm:gap-8 min-w-0">
		
		<!-- Title & Metadata -->
		<div class="flex-1 min-w-0">
			<h3 class="text-xs sm:text-sm font-normal text-slate-800 leading-tight line-clamp-1 cursor-text select-text group-hover:text-[#0e7045] transition-colors">
				{{ pTitle }}
			</h3>
			
			<div class="mt-1 flex flex-wrap items-center gap-1.5 sm:gap-2 text-[10px]">
				<span class="bg-slate-100 text-slate-500 font-semibold px-1.5 py-0.5 rounded uppercase select-all">ID: {{ item.id }}</span>
				<span class="bg-slate-100 text-slate-500 font-semibold px-1.5 py-0.5 rounded uppercase select-all">IKU: {{ item.iku|default('N/A') }}</span>
                
				{% if extras.idSrc is defined and extras.idSrc is not empty %}
				    <span class="bg-[#0e7045]/5 text-[#0e7045] font-semibold px-1.5 py-0.5 rounded uppercase border border-[#0e7045]/10 select-all">SRC: {{ extras.idSrc }}</span>
				{% endif %}

				<span class="text-[#0e7045] font-semibold uppercase tracking-wider flex items-center gap-1 ml-auto sm:ml-0">
					<span class="w-1 h-1 rounded-full bg-[#0e7045] animate-pulse"></span>
					Disponible
				</span>
			</div>
		</div>

		<!-- Price & Actions -->
		<div class="flex-shrink-0 flex items-center justify-between sm:justify-end gap-3 sm:gap-4">
			<div class="flex flex-col items-end">
				<span class="font-bold text-slate-800 text-sm sm:text-base">
					${{ item.price|number_format(2, '.', ',') }}
				</span>
			</div>
			
			<div class="flex items-center gap-1.5 sm:gap-2">
				<!-- Info Button (Ficha) -->
				<button @click.stop="if (window.innerWidth >= 1024) { openModal(JSON.parse($el.closest('[data-item]').getAttribute('data-item'))); } else { window.location.href = '{{ detailUrl }}'; }"
								class="p-1.5 text-slate-400 hover:text-blue-500 hover:bg-blue-50 rounded-lg transition-all active:scale-90"
								title="Ver detalles">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
				</button>

				{% if isMeli %}
					<a href="{{ detailUrl }}" target="_blank" class="px-2.5 py-1.5 bg-yellow-400 text-slate-800 font-bold text-[9px] uppercase tracking-wider rounded-lg shadow-sm hover:bg-yellow-500 active:scale-95 transition-all">
						Meli
					</a>
				{% else %}
					<template x-if="!({{ safeId }} in cartItems)">
						<button @click.stop="addToCart({{ safeId }})" 
									class="p-1.5 bg-slate-100 text-slate-600 hover:bg-[#0e7045]/10 hover:text-[#0e7045] hover:border-[#0e7045]/20 border border-slate-200/60 rounded-lg transition-all active:scale-90">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
						</button>
					</template>
					<template x-if="{{ safeId }} in cartItems">
						<button @click.stop="promptRemove({{ safeId }})" 
									class="p-1.5 bg-[#0e7045]/10 text-[#0e7045] hover:bg-red-50 hover:text-red-500 hover:border-red-200 border border-[#0e7045]/20 rounded-lg transition-all active:scale-90">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
						</button>
					</template>
				{% endif %}
			</div>
		</div>
	</div>
</div>
