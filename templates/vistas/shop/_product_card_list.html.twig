{% set extras = item.extras %}
{% set firstPic = (extras.pictures|default([]))|first %}
{% set mainImg = item.thumb %}
{% if extras.pathImg is defined and firstPic %}
    {% set mainImg = (firstPic starts with 'http' or firstPic starts with '/' or firstPic starts with '//') ? firstPic : extras.pathImg ~ '/' ~ firstPic %}
{% endif %}
{% set placeholder = 'https://placehold.co/600x600/f5f5f5/a3a3a3?text=Sin+Foto' %}
{% set modalData = {
    id: item.id,
    title: item.title,
    price: item.price,
    thumb: mainImg,
    imgBig: mainImg,
    detalles: item.detalles|default(''),
    sku: item.iku|default('N/A'),
    brand: item.mrkId,
    model: item.mdlId,
    pieza: item.pieza|default(''),
    lado: item.lado|default(''),
    poss: item.poss|default(''),
    anioInicio: item.anioInicio|default(0),
    anioFin: item.anioFin|default(9999),
    pictures: extras.pictures|default([]),
    pathImg: extras.pathImg|default(''),
    mk: extras.mk|default(''),
    md: extras.md|default(''),
    numPart: extras.numPart|default(''),
    localidad: extras.localidad|default(''),
    idSrc: extras.idSrc|default(''),
    linkSr: extras.linkSr|default(''),
    fuente: extras.fuente|default(''),
    calif: extras.calif|default(0)
}|json_encode %}
{% set cleanSlug = item.title|lower|replace({' ': '-', '/': '-', '\\': '-'})|url_encode|slice(0, 50) %}

{% set isMeli = isMeli|default(false) %}
{% set safeId = item.id ?: 0 %}
{% set detailUrl = isMeli and extras.permalink is defined ? extras.permalink : path('app_product_detail', { id: safeId, slug: cleanSlug }) %}

<div class="group bg-white flex items-center p-2 sm:p-2.5 gap-3 sm:gap-4 rounded-lg border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all duration-200"
     {{ ('data-item="' ~ modalData|e('html_attr') ~ '"')|raw }}>

	<!-- Thumbnail -->
	<div class="w-12 h-12 sm:w-14 sm:h-14 flex-shrink-0 rounded-lg bg-gray-50 overflow-hidden border border-gray-100">
		<img src="{{ mainImg }}" 
			 onerror="this.src='{{ placeholder }}'"
			 class="w-full h-full object-cover" 
			 alt="{{ item.title }}" loading="lazy">
	</div>

	<!-- Content -->
	<div class="flex-1 flex flex-col sm:flex-row sm:items-center justify-between gap-2 sm:gap-6 min-w-0">
		
		<div class="flex-1 min-w-0">
			<h3 class="text-sm font-medium text-gray-800 leading-snug line-clamp-1 group-hover:text-primary transition-colors">
				{{ item.title }}
			</h3>
			<div class="mt-0.5 flex flex-wrap items-center gap-1.5">
				<span class="text-[10px] text-gray-400 font-medium">ID: {{ item.id }}</span>
				<span class="text-[10px] text-gray-400">·</span>
				<span class="text-[10px] text-gray-400 font-medium">{{ item.iku|default('N/A') }}</span>
				{% if extras.idSrc is defined and extras.idSrc is not empty %}
				    <span class="text-[10px] text-primary/60 font-medium">· SRC: {{ extras.idSrc }}</span>
				{% endif %}
			</div>
		</div>

		<div class="flex items-center gap-3 sm:gap-4 flex-shrink-0">
			<span class="font-bold text-gray-900 text-sm sm:text-base whitespace-nowrap">
				${{ item.price|number_format(2, '.', ',') }}
			</span>
			
			<div class="flex items-center gap-1.5">
				<button @click.stop="openModal(JSON.parse($el.closest('[data-item]').getAttribute('data-item')))"
								class="w-8 h-8 text-gray-300 hover:text-gray-500 hover:bg-gray-50 rounded-lg flex items-center justify-center transition-colors"
								title="Ver detalles">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
				</button>

				{% if isMeli %}
					<a href="{{ detailUrl }}" target="_blank" class="w-8 h-8 bg-[#ffe600] text-[#2d3277] rounded-lg flex items-center justify-center hover:bg-yellow-300 active:scale-95 transition-all">
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
					</a>
				{% else %}
					<template x-if="!({{ safeId }} in cartItems)">
						<button @click.stop="addToCart({{ safeId }})" 
									class="w-8 h-8 bg-primary text-dark rounded-lg flex items-center justify-center hover:bg-emerald-400 active:scale-95 transition-all">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
						</button>
					</template>
					<template x-if="{{ safeId }} in cartItems">
						<button @click.stop="promptRemove({{ safeId }})" 
									class="w-8 h-8 bg-primary/15 text-primary rounded-lg flex items-center justify-center hover:bg-primary/25 active:scale-95 transition-all">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
						</button>
					</template>
				{% endif %}
			</div>
		</div>
	</div>
</div>
