{% extends 'base.html.twig' %}
{% set viewBase = 'vistas/shop' %}

{% block title %}{{ storeName }} | Catálogo Profesional{% endblock %}

{% block meta %}
<meta name="description" content="Explora el catálogo de refacciones premium de {{ storeName }}. Encuentra piezas de calidad para tu vehículo en {{ localidad|default('Guadalajara, Jalisco') }}.">
{% endblock %}

{% block body %}
<div class="min-h-screen bg-[#fafafa] flex flex-col font-sans antialiased" x-data="shopState()">
  
  <!-- Header -->
  <header class="sticky top-0 z-50 bg-dark border-b border-white/[0.06]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-14 flex items-center gap-4 sm:gap-6">

      <!-- Logo -->
      <div class="flex items-center gap-2.5 flex-shrink-0 cursor-pointer select-none" onclick="window.location.href=window.location.pathname">
        {% if dtaCtc.logo is defined and dtaCtc.logo is not empty %}
          <div class="w-8 h-8 rounded-lg overflow-hidden bg-white flex-shrink-0">
            <img src="{{ app.request.getSchemeAndHttpHost() }}{{ app.request.getBasePath() }}/ctc_logo/{{ dtaCtc.logo }}" alt="Logo" class="w-full h-full object-cover">
          </div>
        {% else %}
          <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center flex-shrink-0">
            <svg class="w-4.5 h-4.5 text-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
        {% endif %}
        <span class="text-white font-bold text-sm tracking-tight hidden sm:block">{{ storeName|default('YonkEros') }}</span>
      </div>

      <!-- Search -->
      <div class="flex-1 max-w-md relative hidden md:block" 
           x-data="{ 
              hasMeli: {{ hasMeli|default(false) ? 'true' : 'false' }},
              meliToken: '{{ encodedMeliToken|default('') }}'
           }">
        <div class="relative">
          <svg class="w-4 h-4 absolute left-3.5 top-1/2 -translate-y-1/2 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          <input type="text" x-model="currentFilters.q" 
              @keydown.enter="applyFilter({page: 1})"
              placeholder="Buscar pieza, marca o modelo..." 
              class="w-full bg-white/[0.12] border border-white/[0.15] rounded-lg pl-10 pr-20 py-2.5 text-sm text-white placeholder:text-white/40 focus:bg-white/[0.18] focus:border-primary/40 focus:ring-1 focus:ring-primary/20 outline-none transition-all">
          
          <div class="absolute right-2.5 top-1/2 -translate-y-1/2 flex items-center gap-1">
            <button x-show="currentFilters.q.length > 0" @click="resetSearch()" 
                    class="p-1 text-white/30 hover:text-red-400 rounded transition-colors" x-cloak>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            <button @click="applyFilter({page: 1})" class="p-1.5 bg-primary/20 text-primary hover:bg-primary/30 rounded-md transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </button>
            <template x-if="hasMeli">
              <span class="text-[9px] font-bold text-yellow-300/80 bg-yellow-400/10 px-1.5 py-0.5 rounded ml-1">ML</span>
            </template>
          </div>
        </div>
      </div>

      <!-- Quick Filters -->
      <div class="hidden lg:flex items-center gap-1.5 flex-shrink-0">
        <button class="px-3 py-1.5 text-[11px] font-medium text-white/50 hover:text-white hover:bg-white/[0.08] rounded-md transition-colors">Recientes</button>
        <button class="px-3 py-1.5 text-[11px] font-medium text-white/50 hover:text-white hover:bg-white/[0.08] rounded-md transition-colors">Económicos</button>
        <button class="px-3 py-1.5 text-[11px] font-medium text-white/50 hover:text-white hover:bg-white/[0.08] rounded-md transition-colors">Populares</button>
      </div>

      <!-- Right Actions -->
      <div class="flex items-center gap-2 sm:gap-3 ml-auto">
        <!-- Mobile search toggle -->
        <button class="md:hidden p-2 text-white/50 hover:text-white rounded-lg transition-colors"
                @click="$refs.mobileSearch.classList.toggle('hidden')">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </button>

        <button class="hidden sm:flex items-center gap-2 bg-primary hover:bg-emerald-400 text-dark px-4 py-1.5 rounded-lg text-xs font-semibold transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          Contactar
        </button>

        <div class="relative">
          <button @click="showCart = !showCart" class="p-2 text-white/60 hover:text-white rounded-lg hover:bg-white/[0.06] transition-all relative">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            <span class="absolute -top-0.5 -right-0.5 bg-primary text-dark text-[9px] font-bold min-w-[16px] h-4 flex items-center justify-center rounded-full" 
              x-show="cartCount > 0" x-text="cartCount" x-transition.scale x-cloak></span>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Search Bar -->
    <div class="md:hidden px-4 pb-3 hidden" x-ref="mobileSearch">
      <div class="relative">
        <svg class="w-4 h-4 absolute left-3.5 top-1/2 -translate-y-1/2 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        <input type="text" x-model="currentFilters.q" 
            @keydown.enter="applyFilter({page: 1})"
            placeholder="Buscar pieza..." 
            class="w-full bg-white/[0.12] border border-white/[0.15] rounded-lg pl-10 pr-4 py-2.5 text-sm text-white placeholder:text-white/40 focus:bg-white/[0.18] focus:border-primary/40 outline-none transition-all">
      </div>
    </div>
  </header>

  <!-- Filter Drawer (Mobile & Desktop trigger) -->
  <div class="fixed inset-0 z-[60] overflow-hidden" x-show="showFilters" x-cloak>
    <div class="absolute inset-0 bg-black/30 backdrop-blur-sm" 
      x-show="showFilters" 
      x-transition:enter="ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
      x-transition:leave="ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
      @click="showFilters = false"></div>

    <div class="fixed inset-y-0 left-0 max-w-[300px] w-full bg-white shadow-xl flex flex-col"
      x-show="showFilters"
      x-transition:enter="transform transition ease-out duration-300" x-transition:enter-start="-translate-x-full" x-transition:enter-end="translate-x-0"
      x-transition:leave="transform transition ease-in duration-200" x-transition:leave-start="translate-x-0" x-transition:leave-end="-translate-x-full">

      <div class="flex items-center justify-between px-5 h-14 border-b border-gray-100 flex-shrink-0">
        <span class="text-sm font-semibold text-gray-900">Filtrar por marca</span>
        <button @click="showFilters = false" class="p-1.5 text-gray-400 hover:text-gray-600 rounded-md hover:bg-gray-50 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <div class="flex-1 overflow-y-auto p-4">
        {% include viewBase ~ '/_filter_drawer.html.twig' %}
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 py-6 flex gap-6">
    <!-- Desktop Sidebar -->
    <aside class="w-60 hidden lg:block flex-shrink-0">
      {% include viewBase ~ '/_sidebar.html.twig' %}
    </aside>

    <div class="flex-1 flex flex-col min-w-0">
      <section id="product-grid-container">
        {% include viewBase ~ '/_product_grid.html.twig' %}
      </section>

      <section class="w-full" x-show="meliLoading || meliItemsHtml !== ''" x-cloak>
          <div x-show="meliLoading" class="flex items-center justify-center py-12 gap-3">
              <span class="w-5 h-5 border-2 border-gray-200 border-t-primary rounded-full animate-spin"></span>
              <span class="text-xs text-gray-400 font-medium">Buscando stock extendido...</span>
          </div>
          <div x-html="meliItemsHtml" x-show="!meliLoading"></div>
      </section>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-gray-50 border-t border-gray-100 py-8 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 bg-dark rounded flex items-center justify-center">
          <svg class="w-3 h-3 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <span class="text-sm font-semibold text-gray-500">{{ storeName|default('YonkEros') }}</span>
        <span class="text-xs text-gray-300">· © {{ 'now'|date('Y') }}</span>
      </div>
      <div class="flex gap-6">
          <a href="#" class="text-xs text-gray-400 hover:text-gray-600 transition-colors">Privacidad</a>
          <a href="#" class="text-xs text-gray-400 hover:text-gray-600 transition-colors">Términos</a>
          <a href="#" class="text-xs text-gray-400 hover:text-gray-600 transition-colors">Soporte</a>
      </div>
    </div>
  </footer>

  {% include 'vistas/common/_modal_details.html.twig' %}
  {% include 'vistas/common/_modal_cart.html.twig' %}

  <!-- Toast Notifications -->
  <div class="fixed bottom-6 right-6 z-[100] pointer-events-none flex flex-col gap-2">
    <template x-for="toast in toasts" :key="toast.id">
      <div x-show="true" 
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 translate-y-3 scale-95"
          x-transition:enter-end="opacity-100 translate-y-0 scale-100"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0 scale-95"
          class="bg-dark text-white pl-4 pr-5 py-3 rounded-lg shadow-lg flex items-center gap-3 pointer-events-auto text-sm">
        <div class="w-5 h-5 bg-primary rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-3 h-3 text-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
        </div>
        <span class="text-xs font-medium" x-text="toast.message"></span>
      </div>
    </template>
  </div>

  <!-- Confirm Remove Modal -->
  <div x-show="itemToRemove !== null" class="fixed inset-0 z-[150] flex items-center justify-center p-4" x-cloak>
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" @click="itemToRemove = null" x-transition.opacity></div>
    <div class="relative bg-white rounded-xl p-6 max-w-xs w-full shadow-2xl flex flex-col items-center text-center"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 scale-95"
        x-transition:enter-end="opacity-100 scale-100">
      <div class="w-12 h-12 bg-red-50 rounded-full flex items-center justify-center mb-4">
        <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
      </div>
      <h3 class="text-gray-900 text-sm font-semibold mb-1">¿Quitar del carrito?</h3>
      <p class="text-gray-400 text-xs mb-5">Se eliminará de tu selección.</p>
      <div class="flex gap-3 w-full">
          <button @click="itemToRemove = null" class="flex-1 py-2 rounded-lg text-sm font-medium text-gray-500 hover:bg-gray-50 transition-colors">Cancelar</button>
          <button @click="confirmRemove()" class="flex-1 py-2 rounded-lg text-sm font-medium bg-red-500 text-white hover:bg-red-600 active:scale-[0.98] transition-all">Quitar</button>
      </div>
    </div>
  </div>
</div>

<script>

  function shopState() {

    return {
      selectedItem: null,
      showModal: false,
      showCart: false,
      showFilters: false,
      viewMode: 'grid',
      get cartCount() { return Object.keys(this.cartItems).length; },
      cartItems: {{ app.session.get('cart') ? app.session.get('cart')|json_encode|raw : '{}' }},
      get cartTotal() { 
        return Object.values(this.cartItems).reduce((acc, item) => acc + (parseFloat(item.price) * (item.quantity || 1)), 0); 
      },
      get cartItemsTitles() {
        return Object.values(this.cartItems).map(i => i.title).join(', ');
      },
      quoteForm: { phone: '', email: '' },
      totalItems: {{ items is defined ? items|length : 0 }},
      itemToRemove: null,
      toasts: [],
      currentFilters: { mk: '', md: '', page: 1, q: '{{ search }}' },
      meliToken: '{{ encodedMeliToken|default('') }}',
      storeName: '{{ storeName|default(slug|capitalize)|escape('js') }}',
      localidad: '{{ (dtaCtc.localidad ?? 'Guadalajara, Jalisco')|escape('js') }}',
      meliItemsHtml: '',
      meliLoading: false,
      async applyFilter(params = {}) {
        if ((params.mk !== undefined || params.md !== undefined) && params.q === undefined) {
          this.currentFilters.q = '';
        }

        this.currentFilters = { ...this.currentFilters, ...params };
          
        const queryParams = { ...this.currentFilters };
        if (this.meliToken) {
          queryParams.mt = this.meliToken;
        }
        
        const query = new URLSearchParams(queryParams).toString();
        
        this.meliItemsHtml = '';

        try {
          const res = await fetch(`{{ path('app_shop_search', {template: template, slug: slug}) }}?${query}`);
          document.getElementById('product-grid-container').innerHTML = await res.text();
          this.showFilters = false; 
          
          window.scrollTo({ top: 0, behavior: 'smooth' });

          const urlParams = new URLSearchParams(this.currentFilters);
          const newUrl = window.location.pathname + '?' + urlParams.toString();
          window.history.pushState({}, '', newUrl);
        } catch (e) {
          console.error('Error filtering local DB', e);
        }
      },
      resetSearch() {
        this.applyFilter({mk: '', md: '', q: '', page: 1});
      },
      fetchMissingMeli(ids) {
        if (!ids || ids.trim() === '') {
          this.meliItemsHtml = '';
          return;
        }
        this.meliLoading = true;
        this.meliItemsHtml = '';
        
        const queryParams = { ids: ids };
        if (this.meliToken) queryParams.mt = this.meliToken;
        const query = new URLSearchParams(queryParams).toString();
        
        fetch(`{{ path('app_shop_search_meli', {slug: slug}) }}?${query}`)
            .then(res => {
                if(!res.ok) throw new Error('Network response was not ok');
                return res.text();
            })
            .then(html => { this.meliItemsHtml = html; })
            .catch(e => console.error('Error fetching missing Meli', e))
            .finally(() => { this.meliLoading = false; });
      },
      openModal(item) {
        this.selectedItem = item;
        this.showModal = true;
      },
      async addToCart(id) {
        try {
          const res = await fetch('{{ path('cart_add', {id: 0}) }}'.replace('0', id), { method: 'POST' });
          const data = await res.json();
          if (data.success && data.item) {
            this.cartItems[id] = data.item;
            this.addToast('Producto añadido al carrito');
          }
        } catch (e) {
          console.error('Error adding to cart', e);
        }
      },
      promptRemove(id) {
        this.itemToRemove = id;
      },
      async confirmRemove() {
          const id = this.itemToRemove;
          this.itemToRemove = null;
          delete this.cartItems[id];
          this.addToast('Producto eliminado');
          try {
              await fetch('{{ path('cart_add', {id: 0}) }}'.replace('0', id) + '?remove=1', { method: 'POST' });
          } catch(e) {}
      },
      async clearCart() {
          if (!confirm('¿Seguro que deseas vaciar todo el carrito?')) return;
          this.cartItems = {};
          this.addToast('Carrito vaciado');
          try {
              await fetch('{{ path('cart_clear') }}', { method: 'POST' });
          } catch(e) {}
      },
      async submitQuote() {
        if (!this.quoteForm.email) return;
        this.addToast('Enviando cotización...');
        setTimeout(() => {
            this.showCart = false;
            this.addToast('¡Cotización enviada con éxito!');
        }, 1500);
      },
      addToast(message) {
        const id = Date.now();
        this.toasts.push({ id, message });
        setTimeout(() => {
          this.toasts = this.toasts.filter(t => t.id !== id);
        }, 3000);
      }
    }
  }
</script>
{% endblock %}
