{% extends 'base.html.twig' %}

{% block title %}{{ storeName }} | Catálogo Profesional{% endblock %}

{% block body %}
<div class="min-h-screen bg-[#e8f2ec] flex flex-col font-sans" x-data="shopState()">
  
  <!-- Top Header -->
  <header class="sticky top-0 z-50 bg-[#0b141a] border-b border-white/5 shadow-2xl">
    <div class="max-w-[1600px] mx-auto px-6 h-20 flex items-center gap-8">

      <!-- Floating Graphic Logo -->
      <div class="relative w-20 lg:w-72 h-20 flex-shrink-0">
        <div class="absolute top-3 lg:top-4 left-0 lg:left-1/2 lg:-translate-x-1/2 z-[70] group cursor-pointer" onclick="window.location.href=window.location.pathname">
          <div class="absolute inset-0 bg-[#25d366]/30 blur-2xl rounded-[3rem] transition-all group-hover:bg-[#25d366]/40"></div>
          <div class="relative w-20 h-20 lg:w-36 lg:h-36 {{ dtaCtc.logo is defined and dtaCtc.logo is not empty ? 'bg-[#ffffff]' : 'bg-[#25d366]' }} rounded-[2rem] lg:rounded-[3rem] flex items-center justify-center text-[#0b141a] shadow-[0_20px_30px_-15px_rgba(0,0,0,0.7)] border-2 border-[#0b141a] rotate-0 group-hover:rotate-6 transition-transform duration-500 overflow-hidden">
              {% if dtaCtc.logo is defined and dtaCtc.logo is not empty %}
                <div class="w-full h-full p-1.5 lg:p-1">
                    <div class="w-full h-full bg-white bg-center bg-no-repeat bg-cover rounded-[1.4rem] lg:rounded-[2.4rem] shadow-sm" style="background-image: url('{{ app.request.getSchemeAndHttpHost() }}{{ app.request.getBasePath() }}/ctc_logo/{{ dtaCtc.logo }}');"></div>
                </div>
              {% else %}
                <svg class="w-12 h-12 lg:w-20 lg:h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              {% endif %}
          </div>
        </div>
      </div>

      <div class="flex-1 max-w-2xl relative group hidden md:block" 
           x-data="{ 
              hasMeli: {{ hasMeli|default(false) ? 'true' : 'false' }},
              meliToken: '{{ encodedMeliToken|default('') }}'
           }">
        <div class="relative flex items-center w-full">
          <input type="text" x-model="currentFilters.q" 
              @keydown.enter="applyFilter({page: 1})"
              placeholder="Busca por pieza, marca o código..." 
              class="w-full bg-white/5 border border-white/20 rounded-2xl pl-12 pr-24 py-3 text-sm focus:ring-4 focus:ring-[#25d366]/10 focus:border-[#25d366]/50 focus:bg-white/10 placeholder:text-white/30 transition-all outline-none text-white font-medium">
          <svg class="w-5 h-5 absolute left-4 text-white/30 group-focus-within:text-[#25d366] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          
          <!-- Botón de Búsqueda -->
          <button @click="applyFilter({page: 1})" class="absolute right-16 p-2 text-white/50 hover:text-[#25d366] hover:bg-white/5 rounded-xl transition-all">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </button>
          
          <!-- Status Logos -->
          <div class="absolute right-4 pointer-events-none">
            <template x-if="hasMeli">
              <!-- Meli Logo Style -->
              <div class="h-6 px-2 bg-white/30 rounded-md flex items-center justify-center shadow-sm font-black text-white text-[12px] tracking-tight">
                  MeLi
              </div>
            </template>
            <template x-if="!hasMeli">
              <!-- Yonkeros Logo -->
              <div class="w-6 h-6 bg-[#25d366] rounded-full flex items-center justify-center shadow-sm">
                  <svg class="w-3.5 h-3.5 text-[#0b141a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              </div>
            </template>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-4 ml-auto">
        <button class="flex items-center gap-2 bg-[#25d366] hover:bg-emerald-400 text-darker px-6 py-3 rounded-2xl transition-all shadow-lg shadow-black/10 group">
          <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          <span class="text-xs font-black hidden lg:block tracking-widest uppercase">Contactar</span>
        </button>

        <div class="relative">
          <button @click="showCart = !showCart" class="p-3.5 bg-white/10 border-none rounded-2xl text-white hover:bg-white/20 transition-all group">
            <svg class="w-6 h-6 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            <span class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] font-black w-5 h-5 flex items-center justify-center rounded-full border-2 border-[#0b141a] shadow-md" 
              x-show="cartCount > 0" x-text="cartCount" x-transition.scale x-cloak></span>
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- Sidebar Drawer (Hidden by default) -->
  <div class="fixed inset-0 z-[60] overflow-hidden" x-show="showFilters" x-cloak>
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm transition-opacity" 
      x-show="showFilters" 
      x-transition:enter="ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="ease-in duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      @click="showFilters = false"></div>

    <div class="fixed inset-y-0 left-0 max-w-xs w-full bg-[#e8f2ec] shadow-2xl flex flex-col"
      x-show="showFilters"
      x-transition:enter="transform transition ease-in-out duration-500"
      x-transition:enter-start="-translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transform transition ease-in-out duration-500"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="-translate-x-full">

      <div class="flex items-center justify-between p-6 border-b border-white/10 bg-[#0b141a] text-white">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-[#25d366] rounded-lg flex items-center justify-center text-[#0b141a]">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
          </div>
          <h2 class="text-xs font-black uppercase tracking-widest">Filtrar por Marca</h2>
        </div>
        <button @click="showFilters = false" class="p-2 hover:bg-white/10 rounded-xl transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <div class="flex-1 overflow-y-auto p-4">
        {% include 'vistas/shop/_filter_drawer.html.twig' %}
      </div>
    </div>
  </div>

  <main class="flex-1 max-w-[1600px] mx-auto w-full px-6 py-8 flex gap-8">
    <!-- Sidebar Fijo -->
    <aside class="w-72 hidden lg:block flex-shrink-0">
      {% include 'vistas/shop/_sidebar.html.twig' %}
    </aside>

    <div class="flex-1 flex flex-col min-w-0">
      <!-- Product Grid Section (Reactive Container) -->
      <section class="flex flex-col gap-8" id="product-grid-container">
        <!-- Initial Grid (Server Rendered) -->
        {% include 'vistas/shop/_product_grid.html.twig' %}
      </section>

      <!-- MeLi Results Container -->
      <section class="w-full" x-show="meliLoading || meliItemsHtml !== ''" x-cloak>
          <div x-show="meliLoading" class="flex flex-col items-center justify-center py-16">
              <span class="w-10 h-10 border-4 border-[#25d366]/20 border-t-[#25d366] rounded-full animate-spin"></span>
              <span class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-4">Consultando stock extendido...</span>
          </div>
          <div x-html="meliItemsHtml" x-show="!meliLoading"></div>
      </section>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-[#0b141a] border-t border-white/5 py-12">
    <div class="max-w-[1600px] mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="flex flex-col items-center md:items-start">
        <span class="text-2xl font-black text-white tracking-widest">Yonk<span class="text-[#25d366]">Eros</span></span>
        <p class="text-xs text-white/20 mt-2">© 2024 Todos los derechos reservados.</p>
      </div>
      <div class="flex gap-8">
          <a href="#" class="text-xs font-bold text-slate-500 hover:text-primary transition-colors uppercase tracking-widest">Privacidad</a>
          <a href="#" class="text-xs font-bold text-slate-500 hover:text-primary transition-colors uppercase tracking-widest">Términos</a>
          <a href="#" class="text-xs font-bold text-slate-500 hover:text-primary transition-colors uppercase tracking-widest">Soporte</a>
      </div>
    </div>
  </footer>

  <!-- Modal Details -->
  {% include 'vistas/shop/_modal_details.html.twig' %}

  <!-- Toast Notifications -->
  <div class="fixed bottom-8 right-8 z-[100] pointer-events-none">
    <template x-for="toast in toasts" :key="toast.id">
      <div x-show="true" 
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-4 scale-95"
          x-transition:enter-end="opacity-100 translate-y-0 scale-100"
          x-transition:leave="transition ease-in duration-200"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0 scale-95"
          class="bg-slate-900 text-white px-6 py-4 rounded-2xl shadow-2xl flex items-center gap-4 mb-4 pointer-events-auto border border-white/10">
        <div class="w-8 h-8 bg-primary rounded-full flex items-center justify-center">
          <svg class="w-5 h-5 text-darker" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
        </div>
        <div class="flex flex-col">
          <span class="text-xs font-black tracking-wide uppercase">¡Agregado con éxito!</span>
          <span class="text-[10px] text-slate-400" x-text="toast.message"></span>
        </div>
      </div>
    </template>
  </div>

  <!-- Confirm Remove Modal -->
  <div x-show="itemToRemove !== null" class="fixed inset-0 z-[110] flex items-center justify-center p-4" x-cloak>
      <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-md" @click="itemToRemove = null" x-transition.opacity></div>
      <div class="relative bg-[#0b141a] border border-white/10 rounded-[2.5rem] p-8 max-w-sm w-full shadow-2xl flex flex-col items-center text-center"
           x-transition:enter="transition ease-out duration-300"
           x-transition:enter-start="opacity-0 scale-90 translate-y-8"
           x-transition:enter-end="opacity-100 scale-100 translate-y-0">
          <div class="w-16 h-16 bg-red-500/10 rounded-full flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
          </div>
          <h3 class="text-white text-lg font-black tracking-widest uppercase mb-2">¿Quitar del carrito?</h3>
          <p class="text-white/40 text-xs mb-8 font-medium">El producto se eliminará de tu selección actual.</p>
          <div class="flex gap-4 w-full">
              <button @click="itemToRemove = null" class="flex-1 py-3.5 rounded-2xl font-black text-xs uppercase tracking-widest text-white hover:bg-white/5 transition-colors">Cancelar</button>
              <button @click="confirmRemove()" class="flex-1 py-3.5 rounded-2xl font-black text-xs uppercase tracking-widest bg-red-500 text-white shadow-lg shadow-red-500/20 hover:bg-red-600 active:scale-95 transition-all">Sí, quitar</button>
          </div>
      </div>
  </div>
</div>

<script>

  function shopState() {

    return {
      selectedItem: null,
      showModal: false,
      showFilters: false,
      cartCount: {{ app.session.get('cart')|length }},
      cartItems: {{ app.session.get('cart') ? app.session.get('cart')|keys|json_encode|raw : '[]' }},
      totalItems: {{ items is defined ? items|length : 0 }},
      itemToRemove: null,
      toasts: [],
      currentFilters: { mk: '', md: '', page: 1, q: '{{ search }}' },
      meliToken: '{{ encodedMeliToken|default('') }}',
      storeName: '{{ storeName|default(slug|capitalize)|escape('js') }}',
      localidad: '{{ (dtaCtc.localidad ?? '')|escape('js') }}',
      meliItemsHtml: '',
      meliLoading: false,
      async applyFilter(params = {}) {
          this.currentFilters = { ...this.currentFilters, ...params };
          
          const queryParams = { ...this.currentFilters };
          if (this.meliToken) {
              queryParams.mt = this.meliToken;
          }
          
          const query = new URLSearchParams(queryParams).toString();
          
          this.meliItemsHtml = ''; // Limpiamos resultados anteriores de MeLi

          // 1. Búsqueda local principal (el backend actuará como Metabuscador)
          try {
              const res = await fetch(`{{ path('app_shop_search', {template: template, slug: slug}) }}?${query}`);
              document.getElementById('product-grid-container').innerHTML = await res.text();
              this.showFilters = false; 
              
              // Regresar al principio de la página suavemente
              window.scrollTo({ top: 0, behavior: 'smooth' });

              const urlParams = new URLSearchParams(this.currentFilters);
              const newUrl = window.location.pathname + '?' + urlParams.toString();
              window.history.pushState({}, '', newUrl);
          } catch (e) {
              console.error('Error filtering local DB', e);
          }
      },
      fetchMissingMeli(ids) {
          if (!ids || ids.trim() === '') {
              this.meliItemsHtml = '';
              return;
          }
          this.meliLoading = true;
          this.meliItemsHtml = '';
          
          const queryParams = { ids: ids };
          if (this.meliToken) queryParams.mt = this.meliToken;
          const query = new URLSearchParams(queryParams).toString();
          
          fetch(`{{ path('app_shop_search_meli', {slug: slug}) }}?${query}`)
              .then(res => {
                  if(!res.ok) throw new Error('Network response was not ok');
                  return res.text();
              })
              .then(html => { this.meliItemsHtml = html; })
              .catch(e => console.error('Error fetching missing Meli', e))
              .finally(() => { this.meliLoading = false; });
      },
      openModal(item) {
        this.selectedItem = item;
        this.showModal = true;
        // Preparamos PhotoSwipe si fuera necesario aquí
      },
      async addToCart(id) {
        try {
          const res = await fetch('{{ path('cart_add', {id: 0}) }}'.replace('0', id), { method: 'POST' });
          const data = await res.json();
          if (data.success) {
            this.cartCount = data.cartCount;
            if (!this.cartItems.includes(id)) {
                this.cartItems.push(id);
            }
            this.addToast('Producto añadido al carrito');
          }
        } catch (e) {
          console.error('Error adding to cart', e);
        }
      },
      promptRemove(id) {
        this.itemToRemove = id;
      },
      async confirmRemove() {
          const id = this.itemToRemove;
          this.itemToRemove = null;
          // Actualizar UI optimista
          this.cartItems = this.cartItems.filter(i => i !== id);
          this.cartCount = Math.max(0, this.cartCount - 1);
          this.addToast('Producto eliminado');
          // Llamada al backend si existe (opcional)
          try {
              await fetch('{{ path('cart_add', {id: 0}) }}'.replace('0', id) + '?remove=1', { method: 'POST' });
          } catch(e) {}
      },
      addToast(message) {
        const id = Date.now();
        this.toasts.push({ id, message });
        setTimeout(() => {
          this.toasts = this.toasts.filter(t => t.id !== id);
        }, 3000);
      }
    }
  }
</script>
{% endblock %}
