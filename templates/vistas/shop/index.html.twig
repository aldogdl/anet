{% extends 'base.html.twig' %}
{% set viewBase = 'vistas/shop' %}

{% block title %}{{ storeName }} | Catálogo Profesional{% endblock %}

{% block meta %}
<meta name="description" content="Explora el catálogo de refacciones premium de {{ storeName }}. Encuentra piezas de calidad para tu vehículo en {{ localidad|default('Guadalajara, Jalisco') }}.">
{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-100 flex flex-col font-sans" x-data="shopState()">

  <!-- Top Header (Gradiente Verde Premium de WhatsApp/Marca) -->
  <header class="sticky top-0 z-50 bg-gradient-to-r from-[#0c5e3a] to-[#128c7e] text-white border-b border-[#0c5e3a]/20 shadow-md">
    <div class="max-w-[1440px] mx-auto px-6 h-16 flex items-center gap-8">

      <!-- Logo de la Empresa Integrado y Limpio -->
      <div class="flex items-center gap-3 flex-shrink-0 cursor-pointer" onclick="window.location.href=window.location.pathname">
        <div class="relative w-11 h-11 lg:w-12 h-12 bg-white rounded-xl flex items-center justify-center shadow-md border border-white/20 overflow-hidden">
            {% if dtaCtc.logo is defined and dtaCtc.logo is not empty %}
              <div class="w-full h-full p-0.5">
                  <div class="w-full h-full bg-white bg-center bg-no-repeat bg-cover rounded-lg" style="background-image: url('{{ app.request.getSchemeAndHttpHost() }}{{ app.request.getBasePath() }}/ctc_logo/{{ dtaCtc.logo }}');"></div>
              </div>
            {% else %}
              <svg class="w-6 h-6 text-[#0c5e3a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            {% endif %}
        </div>
        <div class="flex flex-col leading-tight">
          <span class="text-xs font-black text-white tracking-wider uppercase">{{ storeName }}</span>
          <span class="text-[9px] font-semibold text-emerald-200/80 tracking-wider uppercase">Catálogo</span>
        </div>
      </div>

      <!-- Buscador en Píldora Elegante -->
      <div class="flex-1 max-w-xl relative group hidden md:block" 
           x-data="{ 
              hasMeli: {{ hasMeli|default(false) ? 'true' : 'false' }},
              meliToken: '{{ encodedMeliToken|default('') }}'
           }">
        <div class="relative flex items-center w-full">
          <input type="text" x-model="currentFilters.q" 
              @keydown.enter="applyFilter({page: 1})"
              placeholder="Busca por pieza, marca o código..." 
              class="w-full bg-white/10 hover:bg-white/15 focus:bg-white border border-white/10 focus:border-transparent rounded-full pl-10 pr-24 py-2 text-xs focus:ring-2 focus:ring-white/20 focus:text-slate-800 placeholder:text-emerald-100/60 focus:placeholder:text-slate-400 transition-all outline-none text-white font-medium">
          <svg class="w-4 h-4 absolute left-3.5 text-emerald-100/70 group-focus-within:text-[#0c5e3a] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          
          <div class="absolute right-12 flex items-center gap-1">
            <!-- Botón Limpiar -->
            <button x-show="currentFilters.q.length > 0" 
                    @click="resetSearch()" 
                    class="p-1.5 text-emerald-100/70 hover:text-white hover:bg-white/10 rounded-lg transition-all group-focus-within:text-slate-400 group-focus-within:hover:text-red-500 group-focus-within:hover:bg-slate-100"
                    x-cloak x-transition.opacity>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>

            <!-- Botón de Búsqueda -->
            <button @click="applyFilter({page: 1})" class="p-1.5 text-emerald-100/70 hover:text-white hover:bg-white/10 rounded-lg transition-all group-focus-within:text-slate-400 group-focus-within:hover:text-[#0c5e3a] group-focus-within:hover:bg-slate-100">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </button>
          </div>
          
          <!-- Status Logos -->
          <div class="absolute right-3.5 pointer-events-none">
            <template x-if="hasMeli">
              <div class="h-5 px-1.5 bg-[#ffe600] text-slate-800 rounded flex items-center justify-center shadow-sm font-black text-[9px] tracking-tight">
                  MeLi
              </div>
            </template>
            <template x-if="!hasMeli">
              <div class="w-5 h-5 bg-white/20 rounded-full flex items-center justify-center border border-white/20 group-focus-within:bg-[#0c5e3a]/10 group-focus-within:border-[#0c5e3a]/20">
                  <svg class="w-3 text-white group-focus-within:text-[#0c5e3a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              </div>
            </template>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-4 ml-auto">
        <!-- Ayuda Personalizada (Banner Clickeable Refinado) -->
        <a href="{{ path('app_shop_no_encuentro', {slug: slug}) }}" 
           class="hidden lg:flex items-center gap-2.5 px-3.5 py-1.5 bg-white/10 hover:bg-white/20 border border-white/15 rounded-full transition-all duration-300 group">
          <div class="flex flex-col text-right leading-tight">
            <span class="text-emerald-100/80 text-[9px] font-bold uppercase tracking-wider">¿No encuentras tu pieza?</span>
            <span class="text-[11px] text-white font-extrabold uppercase tracking-wide">La conseguimos</span>
          </div>
          <div class="w-5.5 h-5.5 bg-white text-[#0c5e3a] rounded-full flex items-center justify-center transition-transform group-hover:translate-x-0.5 shadow-sm">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg>
          </div>
        </a>

        <!-- Botón Lupa (Buscador Móvil o Alternativo) -->
        <div class="relative md:hidden">
          <button @click="showFilters = !showFilters" class="w-9 h-9 bg-white/10 hover:bg-white/20 border border-white/10 rounded-xl text-white flex items-center justify-center transition-all group">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </button>
        </div>

        <!-- Carrito de Compras Estilizado -->
        <div class="relative">
          <button @click="showCart = !showCart" class="w-10 h-10 bg-white/10 hover:bg-white/20 border border-white/10 rounded-xl text-white flex items-center justify-center transition-all group">
            <svg class="w-5 h-5 group-hover:scale-105 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            <span class="absolute -top-1 -right-1 bg-red-500 text-white text-[9px] font-bold w-4 h-4 flex items-center justify-center rounded-full border border-white shadow-sm" 
              x-show="cartCount > 0" x-text="cartCount" x-transition.scale x-cloak></span>
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- Sidebar Drawer (Hidden by default) -->
  <div class="fixed inset-0 z-[60] overflow-hidden" x-show="showFilters" x-cloak>
    <div class="absolute inset-0 bg-slate-900/30 backdrop-blur-sm transition-opacity" 
      x-show="showFilters" 
      x-transition:enter="ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="ease-in duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      @click="showFilters = false"></div>

    <div class="fixed inset-y-0 left-0 max-w-xs w-full bg-[#f7f9fb] shadow-2xl flex flex-col"
      x-show="showFilters"
      x-transition:enter="transform transition ease-in-out duration-500"
      x-transition:enter-start="-translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transform transition ease-in-out duration-500"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="-translate-x-full">

      <div class="flex items-center justify-between p-5 border-b border-slate-200 bg-white text-slate-800">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-[#0e7045]/10 rounded-lg flex items-center justify-center text-[#0e7045] border border-[#0e7045]/20">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
          </div>
          <h2 class="text-xs font-bold uppercase tracking-wider text-slate-800">Filtrar por Marca</h2>
        </div>
        <button @click="showFilters = false" class="p-2 hover:bg-slate-100 text-slate-500 rounded-xl transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <div class="flex-1 overflow-y-auto p-4">
        {% include viewBase ~ '/_filter_drawer.html.twig' %}
      </div>
    </div>
  </div>

  <main class="flex-1 max-w-[1440px] mx-auto w-full px-6 py-6 flex gap-8">
    <!-- Sidebar Fijo -->
    <aside class="w-72 hidden lg:block flex-shrink-0">
      {% include viewBase ~ '/_sidebar.html.twig' %}
    </aside>

    <div class="flex-1 flex flex-col min-w-0">
      <!-- Product Grid Section (Reactive Container) -->
      <section class="flex flex-col gap-8" id="product-grid-container">
        <!-- Initial Grid (Server Rendered) -->
        {% include viewBase ~ '/_product_grid.html.twig' %}
      </section>

      <!-- MeLi Results Container -->
      <section class="w-full" x-show="meliLoading || meliItemsHtml !== ''" x-cloak>
          <div x-show="meliLoading" class="flex flex-col items-center justify-center py-16">
              <span class="w-10 h-10 border-4 border-[#0e7045]/20 border-t-[#0e7045] rounded-full animate-spin"></span>
              <span class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-4">Consultando stock extendido...</span>
          </div>
          <div x-html="meliItemsHtml" x-show="!meliLoading"></div>
      </section>
    </div>
  </main>

  <!-- Pestaña lateral derecha de WhatsApp (Más visible y elegante) -->
  {% if contactPhone is not empty %}
  <a href="https://wa.me/{{ contactPhone }}?text=Hola,%20estoy%20visitando%20tu%20catálogo%20y%20me%20gustaría%20realizar%20una%20consulta."
     target="_blank"
     class="fixed right-0 top-1/2 -translate-y-1/2 z-[100] flex items-center justify-center bg-[#25d366] hover:bg-[#22c35e] text-white w-12 h-12 sm:w-14 sm:h-14 rounded-l-2xl shadow-[0_10px_30px_rgba(37,211,102,0.4)] hover:pr-1.5 active:scale-95 transition-all duration-300 group">
      <svg class="w-7 h-7 sm:w-8 sm:h-8 text-white group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12.031 0C5.394 0 0 5.394 0 12.031c0 2.115.548 4.17 1.583 5.986L.048 23.518l5.656-1.482a12.002 12.002 0 006.327 1.785h.005c6.634 0 12.029-5.394 12.029-12.031S18.667 0 12.031 0zm0 21.821h-.004a9.986 9.986 0 01-5.088-1.385l-.365-.216-3.782.991.99-3.685-.236-.376a9.986 9.986 0 01-1.526-5.334c0-5.522 4.493-10.017 10.015-10.017 2.675 0 5.188 1.042 7.079 2.934 1.891 1.892 2.932 4.406 2.932 7.081 0 5.524-4.494 10.007-10.014 10.007zm5.493-7.513c-.301-.151-1.785-.882-2.062-.983-.277-.101-.479-.151-.68.151-.202.302-.781.983-.957 1.184-.177.202-.353.227-.654.076-.301-.151-1.275-.47-2.428-1.5-.898-.801-1.503-1.793-1.68-2.095-.177-.302-.019-.465.132-.616.135-.135.301-.353.452-.529.151-.177.202-.302.302-.504.101-.202.05-.378-.025-.529-.076-.151-.68-1.64-.932-2.245-.246-.59-.496-.51-.68-.52-.177-.01-.378-.01-.58-.01-.202 0-.529.076-.806.378-.277.302-1.057 1.033-1.057 2.519s1.083 2.923 1.234 3.125c.151.202 2.13 3.25 5.161 4.557.72.311 1.281.497 1.722.636.723.23 1.381.197 1.902.12.583-.086 1.785-.73 2.036-1.436.252-.705.252-1.309.177-1.436-.076-.126-.277-.202-.578-.353z"></path>
  </a>
  {% endif %}

  <!-- Footer -->
  <footer class="bg-[#0b141a] border-t border-white/5 py-12">
    <div class="max-w-[1600px] mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="flex flex-col items-center md:items-start">
        <span class="text-2xl font-black text-white tracking-widest">Yonk<span class="text-[#0e7045]">Eros</span></span>
        <p class="text-xs text-white/20 mt-2">© 2024 Todos los derechos reservados.</p>
      </div>
      <div class="flex gap-8">
          <a href="#" class="text-xs font-bold text-slate-500 hover:text-primary transition-colors uppercase tracking-widest">Privacidad</a>
          <a href="#" class="text-xs font-bold text-slate-500 hover:text-primary transition-colors uppercase tracking-widest">Términos</a>
          <a href="#" class="text-xs font-bold text-slate-500 hover:text-primary transition-colors uppercase tracking-widest">Soporte</a>
      </div>
    </div>
  </footer>

  {% include 'vistas/common/_modal_details.html.twig' %}
  {% include 'vistas/common/_modal_cart.html.twig' %}

  <!-- Toast Notifications -->
  <div class="fixed bottom-8 right-8 z-[100] pointer-events-none">
    <template x-for="toast in toasts" :key="toast.id">
      <div x-show="true" 
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-4 scale-95"
          x-transition:enter-end="opacity-100 translate-y-0 scale-100"
          x-transition:leave="transition ease-in duration-200"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0 scale-95"
          class="bg-slate-900 text-white px-6 py-4 rounded-2xl shadow-2xl flex items-center gap-4 mb-4 pointer-events-auto border border-white/10">
        <div class="w-8 h-8 bg-primary rounded-full flex items-center justify-center">
          <svg class="w-5 h-5 text-darker" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
        </div>
        <div class="flex flex-col">
          <span class="text-xs font-black tracking-wide uppercase">¡Agregado con éxito!</span>
          <span class="text-[10px] text-slate-400" x-text="toast.message"></span>
        </div>
      </div>
    </template>
  </div>

  <!-- Confirm Remove Modal -->
  <div x-show="itemToRemove !== null" class="fixed inset-0 z-[150] flex items-center justify-center p-4" x-cloak>
    <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-md" @click="itemToRemove = null" x-transition.opacity></div>
    <div class="relative bg-[#0b141a] border border-white/10 rounded-[2.5rem] p-8 max-w-sm w-full shadow-2xl flex flex-col items-center text-center"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 scale-90 translate-y-8"
        x-transition:enter-end="opacity-100 scale-100 translate-y-0">
    <div class="w-16 h-16 bg-red-500/10 rounded-full flex items-center justify-center mb-6">
        <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
    </div>
      <h3 class="text-white text-lg font-black tracking-widest uppercase mb-2">¿Quitar del carrito?</h3>
      <p class="text-white/40 text-xs mb-8 font-medium">El producto se eliminará de tu selección actual.</p>
      <div class="flex gap-4 w-full">
          <button @click="itemToRemove = null" class="flex-1 py-3.5 rounded-2xl font-black text-xs uppercase tracking-widest text-white hover:bg-white/5 transition-colors">Cancelar</button>
          <button @click="confirmRemove()" class="flex-1 py-3.5 rounded-2xl font-black text-xs uppercase tracking-widest bg-red-500 text-white shadow-lg shadow-red-500/20 hover:bg-red-600 active:scale-95 transition-all">Sí, quitar</button>
      </div>
    </div>
  </div>
</div>

<script>

  function shopState() {

    return {
      selectedItem: null,
      showModal: false,
      showCart: false,
      showFilters: false,
      viewMode: 'grid',
      get cartCount() { return Object.keys(this.cartItems).length; },
      cartItems: {{ app.session.get('cart') ? app.session.get('cart')|json_encode|raw : '{}' }},
      get cartTotal() { 
        return Object.values(this.cartItems).reduce((acc, item) => acc + (parseFloat(item.price) * (item.quantity || 1)), 0); 
      },
      get cartItemsTitles() {
        return Object.values(this.cartItems).map(i => i.title).join(', ');
      },
      quoteForm: { phone: '', email: '' },
      totalItems: {{ items is defined ? items|length : 0 }},
      itemToRemove: null,
      toasts: [],
      currentFilters: { mk: '', md: '', page: 1, q: '{{ search }}' },
      meliToken: '{{ encodedMeliToken|default('') }}',
      storeName: '{{ storeName|default(slug|capitalize)|escape('js') }}',
      localidad: '{{ (dtaCtc.localidad ?? 'Guadalajara, Jalisco')|escape('js') }}',
      meliItemsHtml: '',
      meliLoading: false,
      async applyFilter(params = {}) {
        // Si el filtro viene de marcas/modelos, limpiamos la búsqueda de texto
        if ((params.mk !== undefined || params.md !== undefined) && params.q === undefined) {
          this.currentFilters.q = '';
        }

        this.currentFilters = { ...this.currentFilters, ...params };
          
        const queryParams = { ...this.currentFilters };
        if (this.meliToken) {
          queryParams.mt = this.meliToken;
        }
        
        const query = new URLSearchParams(queryParams).toString();
        
        this.meliItemsHtml = ''; // Limpiamos resultados anteriores de MeLi

        // 1. Búsqueda local principal (el backend actuará como Metabuscador)
        try {
          const res = await fetch(`{{ path('app_shop_search', {template: template, slug: slug}) }}?${query}`);
          document.getElementById('product-grid-container').innerHTML = await res.text();
          this.showFilters = false; 
          
          // Regresar al principio de la página suavemente
          window.scrollTo({ top: 0, behavior: 'smooth' });

          const urlParams = new URLSearchParams(this.currentFilters);
          const newUrl = window.location.pathname + '?' + urlParams.toString();
          window.history.pushState({}, '', newUrl);
        } catch (e) {
          console.error('Error filtering local DB', e);
        }
      },
      resetSearch() {
        this.applyFilter({mk: '', md: '', q: '', page: 1});
      },
      fetchMissingMeli(ids) {
        if (!ids || ids.trim() === '') {
          this.meliItemsHtml = '';
          return;
        }
        this.meliLoading = true;
        this.meliItemsHtml = '';
        
        const queryParams = { ids: ids };
        if (this.meliToken) queryParams.mt = this.meliToken;
        const query = new URLSearchParams(queryParams).toString();
        
        fetch(`{{ path('app_shop_search_meli', {slug: slug}) }}?${query}`)
            .then(res => {
                if(!res.ok) throw new Error('Network response was not ok');
                return res.text();
            })
            .then(html => { this.meliItemsHtml = html; })
            .catch(e => console.error('Error fetching missing Meli', e))
            .finally(() => { this.meliLoading = false; });
      },
      openModal(item) {
        this.selectedItem = item;
        this.showModal = true;
        // Preparamos PhotoSwipe si fuera necesario aquí
      },
      async addToCart(id) {
        try {
          const res = await fetch('{{ path('cart_add', {id: 0}) }}'.replace('0', id), { method: 'POST' });
          const data = await res.json();
          if (data.success && data.item) {
            this.cartItems[id] = data.item;
            this.addToast('Producto añadido al carrito');
          }
        } catch (e) {
          console.error('Error adding to cart', e);
        }
      },
      promptRemove(id) {
        this.itemToRemove = id;
      },
      async confirmRemove() {
          const id = this.itemToRemove;
          this.itemToRemove = null;
          delete this.cartItems[id];
          this.addToast('Producto eliminado');
          try {
              await fetch('{{ path('cart_add', {id: 0}) }}'.replace('0', id) + '?remove=1', { method: 'POST' });
          } catch(e) {}
      },
      async clearCart() {
          if (!confirm('¿Seguro que deseas vaciar todo el carrito?')) return;
          this.cartItems = {};
          this.addToast('Carrito vaciado');
          try {
              await fetch('{{ path('cart_clear') }}', { method: 'POST' });
          } catch(e) {}
      },
      async submitQuote() {
        if (!this.quoteForm.email) return;
        this.addToast('Enviando cotización...');
        // Aquí podrías enviar los datos al backend
        setTimeout(() => {
            this.showCart = false;
            this.addToast('¡Cotización enviada con éxito!');
        }, 1500);
      },
      addToast(message) {
        const id = Date.now();
        this.toasts.push({ id, message });
        setTimeout(() => {
          this.toasts = this.toasts.filter(t => t.id !== id);
        }, 3000);
      }
    }
  }
</script>
{% endblock %}
