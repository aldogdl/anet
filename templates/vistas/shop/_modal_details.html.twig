<div id="modal-pro" 
     x-show="showModal" 
     x-cloak
     class="fixed inset-0 z-[100] flex items-center justify-center p-4 lg:p-12 overflow-hidden"
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100">
    
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-xl" @click="showModal = false"></div>

    <!-- Modal Content -->
    <div class="relative bg-[#111b21] w-full max-w-7xl h-full max-h-[900px] rounded-[3rem] shadow-2xl flex flex-col lg:flex-row overflow-hidden border border-white/5"
         x-transition:enter="transition ease-out duration-500 delay-100"
         x-transition:enter-start="opacity-0 translate-y-12 scale-95"
         x-transition:enter-end="opacity-100 translate-y-0 scale-100">
        
        <!-- Close Button -->
        <button @click="showModal = false" class="absolute top-6 right-6 z-10 p-4 bg-white/5 hover:bg-red-500 hover:text-white rounded-2xl transition-all shadow-xl group border border-white/5">
            <svg class="w-6 h-6 group-hover:rotate-90 transition-transform text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <!-- Left: Image Gallery -->
        <div class="w-full lg:w-3/5 bg-black/10 flex flex-col p-8 lg:p-16 border-r border-white/5 overflow-hidden" 
             x-data="{ activeImg: '', initGallery() { 
                if (window.lightbox) window.lightbox.destroy();
                window.lightbox = new PhotoSwipeLightbox({
                    gallery: '#gallery-pro',
                    children: 'a',
                    pswpModule: () => import('https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.esm.js')
                });
                window.lightbox.init();
             } }" 
             x-init="$watch('selectedItem', v => { 
                activeImg = v ? v.imgBig : ''; 
                $nextTick(() => initGallery());
             })">
            
            <div id="gallery-pro" class="flex-1 flex flex-col gap-8 h-full overflow-hidden">
                <!-- Main Zoomable Image -->
                <a :href="activeImg" 
                   data-pswp-width="1200" 
                   data-pswp-height="1200" 
                   target="_blank"
                   class="flex-1 rounded-[2.5rem] bg-[#0b141a] border border-white/5 shadow-inner overflow-hidden flex items-center justify-center p-8 group cursor-zoom-in relative">
                    <img :src="activeImg" class="w-full h-full object-contain transition-transform duration-700 group-hover:scale-110" />
                    <div class="absolute bottom-6 right-6 bg-black/40 backdrop-blur-md px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest text-[#25d366] flex items-center gap-2 border border-white/5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        Zoom HD
                    </div>
                </a>

                <!-- Thumbnails -->
                <div class="flex gap-4 overflow-x-auto pb-4 no-scrollbar">
                    <template x-for="(pic, index) in selectedItem?.pictures" :key="index">
                        <div class="w-24 h-24 flex-shrink-0 rounded-2xl border-2 transition-all cursor-pointer overflow-hidden p-1 bg-[#0b141a] shadow-sm"
                             :class="activeImg === (selectedItem.pathImg + '/' + pic) ? 'border-[#25d366]' : 'border-transparent opacity-40 hover:opacity-100'"
                             @click="activeImg = selectedItem.pathImg + '/' + pic">
                            <img :src="selectedItem.pathImg + '/' + pic" class="w-full h-full object-cover rounded-xl" />
                        </div>
                    </template>
                </div>
            </div>
        </div>

        <!-- Right: Technical Details -->
        <div class="w-full lg:w-2/5 p-8 lg:p-16 flex flex-col justify-between overflow-y-auto">
            <div>
                <div class="flex items-center gap-2 mb-6">
                    <span class="bg-[#25d366] text-white text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest shadow-lg shadow-[#25d366]/20">Original Certificada</span>
                    <span class="text-[10px] font-bold text-white/20 uppercase tracking-widest" x-text="'SKU: ' + selectedItem?.sku"></span>
                </div>

                <h2 class="text-3xl lg:text-4xl font-black text-white leading-tight tracking-tight mb-4" x-text="selectedItem?.title"></h2>
                
                <div class="flex items-baseline gap-2 mb-8">
                    <span class="text-4xl font-black text-[#25d366] italic" x-text="'$' + Number(selectedItem?.price).toLocaleString()"></span>
                    <span class="text-sm font-bold text-white/20 uppercase tracking-widest">MXN + Envío</span>
                </div>

                <div class="space-y-6 mb-12">
                    <div class="bg-[#0b141a] p-6 rounded-3xl border border-white/5">
                        <h4 class="text-[10px] font-black text-[#25d366] uppercase tracking-widest mb-3">Descripción Técnica</h4>
                        <p class="text-sm text-slate-300 leading-relaxed font-medium" x-text="selectedItem?.detalles"></p>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="p-4 bg-[#0b141a] border border-white/5 rounded-2xl">
                            <span class="text-[9px] font-black text-white/20 uppercase tracking-widest block mb-1">Garantía</span>
                            <span class="text-xs font-bold text-white uppercase">90 Días Naturales</span>
                        </div>
                        <div class="p-4 bg-[#0b141a] border border-white/5 rounded-2xl">
                            <span class="text-[9px] font-black text-white/20 uppercase tracking-widest block mb-1">Envío</span>
                            <span class="text-xs font-bold text-white uppercase">Todo México</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex flex-col gap-4">
                <button @click="addToCart(selectedItem.id)" class="w-full bg-[#25d366] hover:bg-emerald-400 text-white font-black py-5 rounded-[1.5rem] shadow-xl shadow-[#25d366]/20 transition-all flex items-center justify-center gap-3 active:scale-95 group">
                    <svg class="w-6 h-6 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                    AÑADIR AL CARRITO
                </button>
                <button class="w-full bg-white/5 hover:bg-white/10 text-white font-black py-5 rounded-[1.5rem] transition-all flex items-center justify-center gap-3 border border-white/5">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.268 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                    CONSULTAR POR WHATSAPP
                </button>
            </div>
        </div>
    </div>
</div>
