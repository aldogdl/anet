<!-- Logo & Mini Contact Section -->
<div class="p-8 flex flex-col items-center border-b border-white/5">
    <div class="relative w-32 h-32 mb-6 group cursor-pointer" onclick="window.location.href=window.location.pathname">
        <div class="absolute inset-0 bg-[#25d366]/20 blur-2xl rounded-full transition-all group-hover:bg-[#25d366]/30"></div>
        <div class="relative w-full h-full bg-white rounded-3xl flex items-center justify-center text-[#0b141a] shadow-2xl border border-white/10 group-hover:rotate-6 transition-transform duration-500 overflow-hidden p-2">
            {% if dtaCtc.logo is defined and dtaCtc.logo is not empty %}
                <img src="{{ app.request.getSchemeAndHttpHost() }}{{ app.request.getBasePath() }}/ctc_logo/{{ dtaCtc.logo }}" class="w-full h-full object-contain" alt="Logo">
            {% else %}
                <svg class="w-16 h-16 text-[#25d366]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            {% endif %}
        </div>
    </div>

    <h2 class="text-lg font-black text-white tracking-tighter uppercase text-center leading-tight">
        {{ storeName|default('Mi Tienda') }}
    </h2>
    
    <div class="flex flex-col items-center gap-1 mt-4">
        <div class="flex items-center gap-2 px-3 py-1 bg-[#25d366]/10 rounded-full border border-[#25d366]/20">
            <span class="w-1.5 h-1.5 rounded-full bg-[#25d366] animate-pulse"></span>
            <span class="text-[10px] font-black text-[#25d366] uppercase tracking-widest">Tienda Online</span>
        </div>
        {% if contactPhone %}
            <a href="https://wa.me/{{ contactPhone }}" target="_blank" class="flex items-center gap-2 mt-2 text-slate-400 hover:text-white transition-colors group">
                <svg class="w-4 h-4 text-[#25d366] group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                <span class="text-xs font-black tracking-widest">{{ contactPhone }}</span>
            </a>
        {% endif %}
    </div>
</div>

<!-- Brands Filter (Scrollable) -->
<div class="flex-1 overflow-hidden flex flex-col p-6" x-data="{ 
    filters: [], 
    loading: true,
    async fetchFilters() {
        try {
            const res = await fetch('{{ path('app_shop_filters', {slug: slug}) }}?t=' + Date.now());
            this.filters = await res.json();
        } finally {
            this.loading = false;
        }
    }
}" x-init="fetchFilters()">
    <h3 class="text-[10px] font-black text-slate-200 uppercase tracking-widest mb-4 flex items-center justify-between">
        FILTROS DE MARCAS
        <button @click="applyFilter({mk: '', md: '', page: 1})" class="text-[9px] text-primary hover:underline font-black">LIMPIAR</button>
    </h3>
    
    <div class="flex-1 overflow-y-auto space-y-1 -mx-2 px-2 custom-scrollbar" id="brands-list">
        <template x-if="loading">
            <div class="p-4 text-center">
                <span class="text-[10px] text-primary animate-pulse font-bold tracking-widest">CARGANDO FILTROS...</span>
            </div>
        </template>
        
        <template x-for="brand in filters" :key="brand.id">
            <div class="group" x-data="{ open: false }">
                <!-- Brand Row -->
                <button @click="open = !open" 
                        class="w-full flex items-center justify-between py-2 px-3 rounded-xl transition-all group-hover:bg-white/5"
                        :class="open ? 'bg-primary/10 text-primary' : 'text-slate-400'">
                    <div class="flex items-center gap-2">
                        <svg class="w-3 h-3 transition-transform duration-300" 
                             :class="open ? 'rotate-90 text-primary' : 'text-slate-600'"
                             fill="none" stroke="currentColor" viewBox="0 0 24 24">
                             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path>
                        </svg>
                        <span class="text-[11px] font-bold uppercase tracking-tight" x-text="brand.name"></span>
                    </div>
                    <span class="text-[9px] font-black opacity-40" x-text="brand.count"></span>
                </button>

                <!-- Models Submenu -->
                <div x-show="open" x-collapse class="ml-6 mt-1 mb-2 space-y-1 border-l border-slate-800 pl-3">
                    <button @click="applyFilter({mk: brand.id, md: '', page: 1})" 
                            class="w-full text-left py-1.5 px-3 text-[10px] font-black text-slate-500 hover:text-primary transition-colors uppercase tracking-widest">
                        VER TODO
                    </button>
                    <template x-for="model in brand.models" :key="model.id">
                        <button @click="applyFilter({mk: brand.id, md: model.id, page: 1})" 
                                class="w-full text-left py-1.5 px-3 text-[10px] font-bold text-slate-600 hover:text-primary transition-colors uppercase tracking-tight"
                                x-text="model.name"></button>
                    </template>
                </div>
            </div>
        </template>
    </div>
</div>
