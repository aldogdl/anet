{% extends 'base.html.twig' %}

{% block title %}{{ storeName }} | Muro de Refacciones{% endblock %}

{% block meta %}
<meta name="description" content="Bienvenido al muro de refacciones de {{ storeName }}. Calidad premium en cada pieza para tu vehículo.">
{% endblock %}

{% block body %}
<div class="flex h-screen overflow-hidden bg-[#0b141a]" x-data="shopState()">
    <!-- Sidebar (Desktop) -->
    <aside class="hidden lg:flex w-80 flex-shrink-0 flex-col border-r border-white/5 bg-[#0b141a]">
        {% include 'vistas/muro/_sidebar.html.twig' %}
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 bg-[#111b21] overflow-y-auto custom-scrollbar relative" id="main-scroll-container">
        <!-- Hero Banner -->
        <div class="relative h-[210px] lg:h-[280px] flex items-center justify-center overflow-hidden">
            <img src="https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?auto=format&fit=crop&q=80&w=1600" 
                 class="absolute inset-0 w-full h-full object-cover opacity-20 grayscale hover:grayscale-0 transition-all duration-1000 scale-110" 
                 alt="Muro de refacciones">
            <div class="absolute inset-0 bg-gradient-to-t from-[#111b21] via-transparent to-transparent"></div>
            
            <div class="relative z-10 text-center px-4">
                <h1 class="text-3xl lg:text-5xl font-black text-white uppercase tracking-tighter hero-text-shadow">
                    Bienvenido a mi <span class="text-[#25d366] italic">MURO</span>
                </h1>
                <p class="mt-2 text-base lg:text-lg text-slate-400 font-light max-w-2xl mx-auto hero-text-shadow">
                    Calidad premium en cada refacción.
                </p>
            </div>
        </div>

        <!-- Sticky Search Bar -->
        <div class="sticky top-0 z-30 bg-[#0b141a]/80 backdrop-blur-xl border-b border-white/5 py-4 px-6 lg:px-12">
            <div class="max-w-6xl mx-auto flex flex-col md:flex-row gap-4 items-center">
                <div class="flex-1 w-full flex items-stretch gap-2">
                    <div class="relative flex-1 group">
                        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-white/20 group-focus-within:text-[#25d366] transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        </span>
                        <input type="text" x-model="currentFilters.q" 
                               @keydown.enter="applyFilter({page: 1})"
                               placeholder="Busca por pieza, marca o código..." 
                               class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-12 pr-4 text-white focus:ring-4 focus:ring-[#25d366]/10 focus:border-[#25d366]/50 outline-none transition-all shadow-2xl placeholder:text-white/20">
                        
                        <!-- Botón Limpiar -->
                        <button x-show="currentFilters.q.length > 0" 
                                @click="resetSearch()" 
                                class="absolute right-4 top-1/2 -translate-y-1/2 p-2 text-white/20 hover:text-red-400 transition-all"
                                x-cloak x-transition.opacity>
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
                        </button>
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <button @click="showCart = !showCart" class="relative p-4 bg-white/5 rounded-2xl border border-white/10 hover:border-[#25d366]/50 group transition-all">
                        <svg class="w-6 h-6 text-white/40 group-hover:text-[#25d366]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                        <span x-show="cartCount > 0" class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] font-black w-5 h-5 flex items-center justify-center rounded-full border-2 border-[#0b141a]" x-text="cartCount" x-transition.scale x-cloak></span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Content Grid (Reactive Container) -->
        <div class="px-6 lg:px-12 py-12 max-w-7xl mx-auto flex flex-col gap-12">
            <section id="product-grid-container">
                {% include 'vistas/muro/_product_grid.html.twig' %}
            </section>

            <!-- MeLi Results Container -->
            <section class="w-full" x-show="meliLoading || meliItemsHtml !== ''" x-cloak>
                <div x-show="meliLoading" class="flex flex-col items-center justify-center py-16">
                    <span class="w-10 h-10 border-4 border-[#25d366]/20 border-t-[#25d366] rounded-full animate-spin"></span>
                    <span class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-4">Consultando stock extendido...</span>
                </div>
                <div x-html="meliItemsHtml" x-show="!meliLoading"></div>
            </section>
        </div>
    </main>

    {% include 'vistas/common/_modal_details.html.twig' %}
    {% include 'vistas/common/_modal_cart.html.twig' %}

    <!-- Toast Notifications -->
    <div class="fixed bottom-8 right-8 z-[100] pointer-events-none">
        <template x-for="toast in toasts" :key="toast.id">
            <div x-show="true" 
                x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="opacity-0 translate-y-4 scale-95"
                x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                x-transition:leave="transition ease-in duration-200"
                x-transition:leave-start="opacity-100"
                x-transition:leave-end="opacity-0 scale-95"
                class="bg-slate-900 text-white px-6 py-4 rounded-2xl shadow-2xl flex items-center gap-4 mb-4 pointer-events-auto border border-white/10">
                <div class="w-8 h-8 bg-[#25d366] rounded-full flex items-center justify-center">
                    <svg class="w-5 h-5 text-[#0b141a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <div class="flex flex-col">
                    <span class="text-xs font-black tracking-wide uppercase">¡Agregado con éxito!</span>
                    <span class="text-[10px] text-slate-400" x-text="toast.message"></span>
                </div>
            </div>
        </template>
    </div>

    <!-- Confirm Remove Modal -->
    <div x-show="itemToRemove !== null" class="fixed inset-0 z-[150] flex items-center justify-center p-4" x-cloak>
        <div class="absolute inset-0 bg-[#0b141a]/80 backdrop-blur-md" @click="itemToRemove = null" x-transition.opacity></div>
        <div class="relative bg-[#0b141a] border border-white/10 rounded-[2.5rem] p-8 max-w-sm w-full shadow-2xl flex flex-col items-center text-center"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 scale-90 translate-y-8"
            x-transition:enter-end="opacity-100 scale-100 translate-y-0">
            <div class="w-16 h-16 bg-red-500/10 rounded-full flex items-center justify-center mb-6">
                <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </div>
            <h3 class="text-white text-lg font-black tracking-widest uppercase mb-2">¿Quitar del carrito?</h3>
            <p class="text-white/40 text-xs mb-8 font-medium">El producto se eliminará de tu selección actual.</p>
            <div class="flex gap-4 w-full">
                <button @click="itemToRemove = null" class="flex-1 py-3.5 rounded-2xl font-black text-xs uppercase tracking-widest text-white hover:bg-white/5 transition-colors">Cancelar</button>
                <button @click="confirmRemove()" class="flex-1 py-3.5 rounded-2xl font-black text-xs uppercase tracking-widest bg-red-500 text-white shadow-lg shadow-red-500/20 hover:bg-red-600 active:scale-95 transition-all">Sí, quitar</button>
            </div>
        </div>
    </div>
</div>

<script>
    function shopState() {
        return {
            selectedItem: null,
            showModal: false,
            showCart: false,
            showFilters: false,
            get cartCount() { return Object.keys(this.cartItems).length; },
            cartItems: {{ app.session.get('cart') ? app.session.get('cart')|json_encode|raw : '{}' }},
            get cartTotal() { 
                return Object.values(this.cartItems).reduce((acc, item) => acc + (parseFloat(item.price) * (item.quantity || 1)), 0); 
            },
            get cartItemsTitles() {
                return Object.values(this.cartItems).map(i => i.title).join(', ');
            },
            itemToRemove: null,
            toasts: [],
            currentFilters: { mk: '', md: '', page: 1, q: '{{ search }}' },
            meliToken: '{{ encodedMeliToken|default('') }}',
            storeName: '{{ storeName|default(slug|capitalize)|escape('js') }}',
            localidad: '{{ (dtaCtc.localidad ?? '')|escape('js') }}',
            meliItemsHtml: '',
            meliLoading: false,

            async applyFilter(params = {}) {
                if ((params.mk !== undefined || params.md !== undefined) && params.q === undefined) {
                    this.currentFilters.q = '';
                }

                this.currentFilters = { ...this.currentFilters, ...params };
                const queryParams = { ...this.currentFilters };
                if (this.meliToken) queryParams.mt = this.meliToken;
                
                const query = new URLSearchParams(queryParams).toString();
                this.meliItemsHtml = ''; 

                try {
                    // USAMOS app_shop_search que ya está optimizado para devolver solo el grid
                    const res = await fetch(`{{ path('app_shop_search', {template: template, slug: slug}) }}?${query}`);
                    document.getElementById('product-grid-container').innerHTML = await res.text();
                    this.showFilters = false; 
                    
                    document.getElementById('main-scroll-container').scrollTo({ top: 0, behavior: 'smooth' });

                    const urlParams = new URLSearchParams(this.currentFilters);
                    const newUrl = window.location.pathname + '?' + urlParams.toString();
                    window.history.pushState({}, '', newUrl);
                } catch (e) {
                    console.error('Error filtering muro', e);
                }
            },
            resetSearch() {
                this.applyFilter({mk: '', md: '', q: '', page: 1});
            },
            fetchMissingMeli(ids) {
                if (!ids || ids.trim() === '') {
                    this.meliItemsHtml = '';
                    return;
                }
                this.meliLoading = true;
                this.meliItemsHtml = '';
                
                const queryParams = { ids: ids };
                if (this.meliToken) queryParams.mt = this.meliToken;
                const query = new URLSearchParams(queryParams).toString();
                
                fetch(`{{ path('app_shop_search_meli', {slug: slug}) }}?${query}`)
                    .then(res => res.text())
                    .then(html => { this.meliItemsHtml = html; })
                    .catch(e => console.error('Error fetching missing Meli', e))
                    .finally(() => { this.meliLoading = false; });
            },
            openModal(item) {
                this.selectedItem = item;
                this.showModal = true;
            },
            async addToCart(id) {
                try {
                    const res = await fetch('{{ path('cart_add', {id: 0}) }}'.replace('0', id), { method: 'POST' });
                    const data = await res.json();
                    if (data.success && data.item) {
                        this.cartItems[id] = data.item;
                        this.addToast('Producto añadido al carrito');
                    }
                } catch (e) {
                    console.error('Error adding to cart', e);
                }
            },
            promptRemove(id) {
                this.itemToRemove = id;
            },
            async confirmRemove() {
                const id = this.itemToRemove;
                this.itemToRemove = null;
                delete this.cartItems[id];
                this.addToast('Producto eliminado');
                try {
                    await fetch('{{ path('cart_add', {id: 0}) }}'.replace('0', id) + '?remove=1', { method: 'POST' });
                } catch(e) {}
            },
            async clearCart() {
                if (!confirm('¿Seguro que deseas vaciar todo el carrito?')) return;
                this.cartItems = {};
                this.addToast('Carrito vaciado');
                try {
                    await fetch('{{ path('cart_clear') }}', { method: 'POST' });
                } catch(e) {}
            },
            addToast(message) {
                const id = Date.now();
                this.toasts.push({ id, message });
                setTimeout(() => {
                    this.toasts = this.toasts.filter(t => t.id !== id);
                }, 3000);
            }
        }
    }
</script>
{% endblock %}

