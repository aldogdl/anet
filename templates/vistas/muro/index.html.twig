{% extends 'base.html.twig' %}

{% block body %}
<div class="flex h-screen overflow-hidden bg-darker" x-data="{ 
    sidebarOpen: false,
    modalOpen: false, 
    selectedItem: null,
    cartCount: {{ app.session.get('cart')|length }},
    gridHtml: '',
    currentFilters: { mk: '', md: '', page: 1, q: '{{ search }}' },

    async applyFilter(params = {}) {
        this.currentFilters = { ...this.currentFilters, ...params };
        const query = new URLSearchParams({ 
            ...this.currentFilters, 
            ajax: 1 
        }).toString();

        try {
            const res = await fetch(`{{ path('app_shop', {template: template, slug: slug}) }}?${query}`);
            this.gridHtml = await res.text();
            
            const newUrl = window.location.pathname + '?' + new URLSearchParams(this.currentFilters).toString();
            window.history.pushState({}, '', newUrl);
        } catch (e) {
            console.error('Error filtering muro', e);
        }
    },

    openModal(item) {
        this.selectedItem = item;
        this.modalOpen = true;
    },
    async addToCart(id) {
        const res = await fetch('{{ path('cart_add', {id: 0}) }}'.replace('0', id), { method: 'POST' });
        const data = await res.json();
        if (data.success) {
            this.cartCount = data.cartCount;
        }
    }
}">
    <!-- Sidebar (Desktop) -->
    <aside class="hidden lg:flex w-80 flex-shrink-0 flex-col border-r border-slate-800 bg-darker">
        {% include 'vistas/muro/_sidebar.html.twig' %}
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 bg-dark overflow-y-auto custom-scrollbar relative">
        <!-- Hero Banner -->
        <div class="relative h-[210px] lg:h-[280px] flex items-center justify-center overflow-hidden">
            <img src="https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?auto=format&fit=crop&q=80&w=1600" 
                 class="absolute inset-0 w-full h-full object-cover opacity-40 grayscale hover:grayscale-0 transition-all duration-1000 scale-110" 
                 alt="Muro de refacciones">
            <div class="absolute inset-0 bg-gradient-to-t from-darker via-transparent to-transparent"></div>
            
            <div class="relative z-10 text-center px-4">
                <h1 class="text-3xl lg:text-5xl font-black text-white uppercase tracking-tighter hero-text-shadow">
                    Bienvenido a mi <span class="text-primary italic">MURO</span>
                </h1>
                <p class="mt-2 text-base lg:text-lg text-slate-300 font-light max-w-2xl mx-auto hero-text-shadow">
                    Calidad premium en cada refacción.
                </p>
            </div>
        </div>

        <!-- Sticky Search Bar -->
        <div class="sticky top-0 z-30 bg-darker/80 backdrop-blur-xl border-b border-slate-800 py-4 px-6 lg:px-12">
            <div class="max-w-6xl mx-auto flex flex-col md:flex-row gap-4 items-center">
                <div class="flex-1 w-full flex items-stretch gap-2">
                    <div class="relative flex-1">
                        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-500">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        </span>
                        <input type="text" x-model="currentFilters.q" 
                               @input.debounce.500ms="applyFilter({page: 1})"
                               placeholder="Buscar en el muro..." 
                               class="w-full bg-slate-800 border border-slate-700 rounded-2xl py-4 pl-12 pr-4 text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all shadow-xl">
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <button class="relative p-4 bg-slate-800 rounded-2xl border border-slate-700 hover:border-primary group transition-all">
                        <svg class="w-6 h-6 text-slate-400 group-hover:text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        <span x-show="cartCount > 0" class="absolute -top-1 -right-1 bg-primary text-darker text-[10px] font-bold w-5 h-5 flex items-center justify-center rounded-full border-2 border-darker" x-text="cartCount"></span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Content Grid (Reactive) -->
        <div class="px-6 lg:px-12 py-12 max-w-7xl mx-auto" x-html="gridHtml" x-init="applyFilter()">
            {% include 'vistas/muro/_product_grid.html.twig' %}
        </div>
    </main>

    {% include 'vistas/muro/_modal_details.html.twig' %}
</div>
{% endblock %}
