{% if items|length > 0 %}
	<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
		{% for item in items %}
			{% include 'vistas/muro/_product_card.html.twig' with {'item': item} %}
		{% endfor %}
	</div>

	{% if pagesCount > 1 %}
    <div class="mt-20 flex justify-center items-center gap-2">
			{% for i in 1..pagesCount %}
				<button @click="applyFilter({page: {{ i }}})" 
					class="w-10 h-10 flex items-center justify-center rounded-xl font-black transition-all {{ i == currentPage ? 'bg-[#25d366] text-[#0b141a] shadow-lg shadow-[#25d366]/20' : 'bg-white/5 text-slate-400 hover:bg-white/10 hover:text-white' }}">
					{{ i }}
				</button>
			{% endfor %}
    </div>
	{% endif %}

    {% if missingIds is defined and missingIds is not empty %}
        <div x-init="fetchMissingMeli('{{ missingIds }}')"></div>
    {% endif %}

{% else %}
	<div class="text-center py-20 bg-black/20 rounded-3xl border border-dashed border-white/5 text-slate-500 font-bold">
		No se encontraron piezas en el muro.
	</div>
{% endif %}

