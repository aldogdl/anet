{% import 'vistas/common/_product_helpers.html.twig' as product %}

{% set extras = item.extras %}
{% set mainImg = product.cardImg(item) %}
{% set firstPic = (extras.pictures|default([]))|first %}
{% set imgBig = product.imgUrl(item, firstPic) %}
{% set title = product.productTitle(item) %}
{% set placeholder = product.placeholder() %}
{% set modalData = {
    id: item.id,
    title: title,
    price: item.price,
    thumb: mainImg,
    imgBig: imgBig,
    detalles: item.detalles|default('Sin detalles adicionales.'),
    sku: item.iku|default('N/A'),
    brand: item.mrkId,
    model: item.mdlId,
    pictures: extras.pictures|default([]),
    pathImg: extras.pathImg|default(''),
    idSrc: extras.idSrc|default(''),
    linkSr: extras.linkSr|default('')
}|json_encode %}
{% set safeId = product.safeId(item) %}

<div class="group bg-[#0b141a] border border-white/5 rounded-3xl overflow-hidden hover:border-[#25d366]/40 transition-all duration-300 flex flex-col h-full shadow-lg hover:shadow-[#25d366]/5 active:scale-[0.98]"
     data-item="{{ modalData|e('html_attr') }}" 
     @click.prevent="openModal(JSON.parse($event.currentTarget.getAttribute('data-item')))">
    
    <!-- Top Accent Line (Optional, but matches shop style) -->
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#25d366]/20 to-transparent"></div>

    <!-- Image Area -->
    <div class="relative aspect-[16/10] overflow-hidden bg-black/20 cursor-pointer">
        <!-- Blurred Background for small images -->
        <div class="absolute inset-0 bg-cover bg-center opacity-40 blur-2xl scale-110" style="background-image: url('{{ mainImg }}')"></div>

        <img src="{{ mainImg }}" 
             onerror="this.onerror=null;this.src='{{ placeholder }}'"
             class="relative z-10 w-full h-full object-contain object-center p-2.5 rounded-3xl group-hover:scale-105 transition-transform duration-700 opacity-90 group-hover:opacity-100" 
             alt="{{ title }}">
        
        <!-- Status Badge -->
        {% if item.isActive %}
            <div class="absolute top-5 left-5 z-20 flex items-center gap-2 bg-[#0b141a]/60 backdrop-blur-md px-3 py-1.5 rounded-full border border-white/10 shadow-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-[#25d366] animate-pulse"></span>
                <span class="text-[9px] font-black text-white uppercase tracking-widest">Disponible</span>
            </div>
        {% endif %}
    </div>

    <!-- Info Area -->
    <div class="p-7 flex-1 flex flex-col">
        <div class="flex-1">
            <h3 class="text-[15px] font-bold text-white leading-tight group-hover:text-[#25d366] transition-colors cursor-pointer overflow-hidden"
                style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; min-height: 3.75rem; max-height: 3.75rem;">
                {{ title }}
            </h3>
            <div class="flex items-center gap-2 mt-2">
                <span class="text-[9px] text-white/40 font-medium uppercase tracking-wider bg-white/5 px-2 py-0.5 rounded">ID: <span class="text-white font-black">{{ item.id }}</span></span>
                <span class="text-[9px] text-white/40 font-medium uppercase tracking-wider bg-blue-600 px-2 py-0.5 rounded">IKU: <span class="text-white font-black">{{ item.iku|default('N/A') }}</span></span>
            </div>
        </div>

        <div class="mt-6 pt-6 border-t border-white/5 flex items-center justify-between gap-4">
            <div class="flex flex-col">
                <span class="text-[10px] text-white/40 font-black uppercase tracking-widest mb-1">Precio Neto</span>
                <span class="text-2xl font-black text-white italic truncate">
                    ${{ item.price|number_format(2, '.', ',') }}
                </span>
            </div>
            
            <div class="flex items-center">
                <template x-if="!({{ safeId }} in cartItems)">
                    <button @click.stop="addToCart({{ safeId }})" 
                            class="p-3.5 bg-white/5 hover:bg-[#25d366] text-white/40 hover:text-[#0b141a] rounded-2xl transition-all shadow-xl active:scale-90 border border-white/10 hover:border-transparent">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4(5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    </button>
                </template>
                <template x-if="{{ safeId }} in cartItems">
                    <button @click.stop="promptRemove({{ safeId }})" 
                            class="p-3.5 bg-[#25d366] text-[#0b141a] rounded-2xl transition-all shadow-lg shadow-[#25d366]/20 active:scale-90">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    </button>
                </template>
            </div>
        </div>
    </div>
</div>


