<div id="modal-pro" 
     x-show="showModal" 
     x-cloak
     x-data="shopModalLogic()"
     x-init="$watch('selectedItem', v => onItemSelected(v))"
     class="fixed inset-0 z-[100] flex items-center justify-center p-3 sm:p-6 overflow-hidden"
     x-transition:enter="transition ease-out duration-200"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100">

    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm z-0" @click="showModal = false"></div>

    <!-- Modal Content -->
    <div class="relative bg-white w-full max-w-5xl max-h-[92vh] rounded-xl shadow-2xl flex flex-col lg:flex-row overflow-hidden z-10"
         x-transition:enter="transition ease-out duration-300 delay-75"
         x-transition:enter-start="opacity-0 translate-y-6 scale-[0.97]"
         x-transition:enter-end="opacity-100 translate-y-0 scale-100">
        
        <!-- Close Button -->
        <button @click="showModal = false" class="absolute top-3 right-3 z-20 p-2 bg-gray-100 hover:bg-red-500 hover:text-white text-gray-400 rounded-lg transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <style>
          .pswp__icn { display: none !important; }
          .pswp__top-bar { display: none !important; }
          .pswp__img { transition: transform 0.3s cubic-bezier(0.33, 1, 0.68, 1) !important; }
          .pswp { z-index: 3000 !important; }
          .pswp__custom-panel { position: absolute !important; bottom: 30px !important; left: 50% !important; transform: translateX(-50%) !important; z-index: 9999 !important; pointer-events: none !important; }
          .pswp__pro-panel { display: flex !important; align-items: center !important; background: rgba(0,0,0,0.8) !important; backdrop-filter: blur(20px) !important; padding: 6px 12px !important; border-radius: 12px !important; gap: 8px !important; pointer-events: auto !important; }
          .pswp__btn-pro { background: transparent !important; border: none !important; width: 40px !important; height: 40px !important; display: flex !important; align-items: center !important; justify-content: center !important; border-radius: 8px !important; transition: all 0.2s !important; cursor: pointer !important; }
          .pswp__btn-pro:hover { background: rgba(255,255,255,0.15) !important; }
          .pswp__divider { width: 1px; height: 20px; background: rgba(255,255,255,0.1); }
        </style>

        <!-- Left: Image Gallery -->
        <div class="w-full lg:w-[55%] bg-[#fafafa] flex flex-col border-r border-gray-100 overflow-hidden">
            <div id="gallery-pro" class="flex-1 flex flex-col h-full overflow-hidden">
                <!-- Main Image Container with Inner Zoom -->
                <div class="w-full aspect-square sm:aspect-[4/3] lg:aspect-square max-h-[350px] sm:max-h-[450px] lg:max-h-[550px] relative group bg-white overflow-hidden border-b border-gray-100 lg:border-b-0">
                    
                    <!-- Zoom Logic Wrapper -->
                    <div class="absolute inset-0 flex items-center justify-center p-4 sm:p-6 cursor-zoom-in"
                         @mousemove="
                            isZoomed = true; 
                            const rect = $el.getBoundingClientRect();
                            let x = ($event.clientX - rect.left) / rect.width;
                            let y = ($event.clientY - rect.top) / rect.height;
                            
                            // Ajustar coordenadas según la rotación
                            if (rotation == 90) { let tmp = x; x = y; y = 1 - tmp; }
                            else if (rotation == 180) { x = 1 - x; y = 1 - y; }
                            else if (rotation == 270) { let tmp = x; x = 1 - y; y = tmp; }
                            
                            zX = x * 100; zY = y * 100;
                         "
                         @mouseleave="isZoomed = false">
                        
                        <div class="w-full h-full flex items-center justify-center transition-transform duration-300"
                             :style="`transform: rotate(${rotation}deg)`">
                            <img :src="activeImg" 
                                 :style="isZoomed ? `transform: scale(2.5); transform-origin: ${zX}% ${zY}%` : ''"
                                 class="max-w-full max-h-full w-auto h-auto object-contain transition-transform duration-200 ease-out pointer-events-none"
                                 alt="Imagen del producto" />
                        </div>
                    </div>

                    <!-- Floating Buttons (Outside the zoom logic wrapper) -->
                    <div class="absolute top-4 right-4 flex flex-col gap-2 z-20">
                        <!-- Magnifying Glass for Lightbox -->
                        <button type="button"
                           class="p-2.5 bg-white/90 backdrop-blur-md border border-gray-100 rounded-lg text-gray-500 hover:text-primary hover:scale-110 transition-all shadow-lg flex items-center justify-center group/lupa"
                           title="Ver pantalla completa"
                           @click.stop="openGalleryManual(activeImg, selectedItem.pictures, selectedItem.pathImg)">
                            <svg class="w-4 h-4 group-hover/lupa:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path>
                            </svg>
                        </button>
                        
                        <!-- Rotate button -->
                        <button @click.stop="rotation = (rotation + 90) % 360" 
                                class="p-2.5 bg-white/90 backdrop-blur-md border border-gray-100 rounded-lg text-gray-500 hover:text-primary hover:scale-110 transition-all shadow-lg flex items-center justify-center"
                                title="Rotar imagen">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                        </button>
                    </div>
                </div>

                <!-- Thumbnails -->
                <div class="flex gap-2 px-4 pb-4 overflow-x-auto no-scrollbar flex-shrink-0">
                    <template x-for="(pic, index) in selectedItem?.pictures" :key="index">
                        <div class="w-14 h-14 sm:w-16 sm:h-16 flex-shrink-0 rounded-lg border-2 transition-all cursor-pointer overflow-hidden bg-white"
                             :class="activeImg === (pic.startsWith('http') ? pic : (selectedItem.pathImg + '/' + pic)) ? 'border-primary' : 'border-gray-100 opacity-50 hover:opacity-100'"
                             @click="activeImg = (pic.startsWith('http') ? pic : (selectedItem.pathImg + '/' + pic)); rotation = 0">
                            <img :src="pic.startsWith('http') ? pic : (selectedItem.pathImg + '/' + pic)" class="w-full h-full object-cover rounded-[5px]" />
                        </div>
                    </template>
                </div>
            </div>
        </div>

        <!-- Right: Details -->
        <div class="w-full lg:w-[45%] flex flex-col overflow-y-auto max-h-[50vh] lg:max-h-none">
            <div class="p-5 sm:p-6 lg:p-8 flex-1">

                <!-- Badges -->
                <div class="flex flex-wrap items-center gap-2 mb-4">
                    <span class="text-[11px] font-medium text-white bg-slate-900 px-2.5 py-1 rounded-md tracking-wider shadow-sm">
                        ID: <span class="font-black" x-text="selectedItem?.id"></span>
                    </span>
                    <span class="text-[11px] font-medium text-white bg-blue-600 px-2.5 py-1 rounded-md tracking-wider shadow-sm">
                        IKU: <span class="font-black" x-text="selectedItem?.sku"></span>
                    </span>
                    <template x-if="selectedItem?.numPart">
                        <span class="text-[11px] font-medium text-primary bg-primary/10 border border-primary/20 px-2.5 py-1 rounded-md tracking-wider" x-text="'N/P: ' + selectedItem?.numPart"></span>
                    </template>
                </div>

                <!-- Title -->
                <h2 class="text-xl sm:text-2xl font-bold text-gray-900 leading-tight tracking-tight mb-1" x-text="selectedItem?.title"></h2>
                
                <!-- Brand / Model -->
                <p class="text-sm text-gray-400 font-medium mb-5" x-show="selectedItem?.mk || selectedItem?.md">
                    <span x-text="selectedItem?.mk"></span>
                    <span x-show="selectedItem?.md"> · <span x-text="selectedItem?.md"></span></span>
                    <span x-show="selectedItem?.anioInicio && selectedItem?.anioInicio > 0">
                        · <span x-text="selectedItem?.anioInicio"></span><span x-show="selectedItem?.anioFin && selectedItem?.anioFin < 9999" x-text="'-' + selectedItem?.anioFin"></span>
                    </span>
                </p>

                <!-- Price + Add to Cart -->
                <div class="flex items-center gap-2 mb-6">
                    <span class="text-3xl font-bold text-gray-900 tracking-tight" x-text="'$' + Number(selectedItem?.price).toLocaleString('es-MX', {minimumFractionDigits: 2})"></span>
                    <span class="text-xs text-gray-400 font-medium">MXN</span>
                    
                    <div class="ml-auto">
                        <template x-if="!cartItems[selectedItem?.id]">
                            <button @click="addToCart(selectedItem.id)" class="bg-dark hover:bg-black text-primary font-bold py-2.5 px-5 rounded-lg transition-all flex items-center justify-center gap-2 active:scale-[0.98] text-sm shadow-lg">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                                Agregar
                            </button>
                        </template>
                        <template x-if="cartItems[selectedItem?.id]">
                            <button @click="promptRemove(selectedItem.id)" class="bg-primary/10 hover:bg-primary/20 text-primary font-bold py-2.5 px-5 rounded-lg transition-all flex items-center justify-center gap-2 active:scale-[0.98] text-sm border border-primary/20">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                                Agregado
                            </button>
                        </template>
                    </div>
                </div>

                <!-- Technical Details Grid -->
                <div class="space-y-4 mb-6">
                    <!-- Description -->
                    <template x-if="selectedItem?.detalles">
                        <div class="bg-gray-50 rounded-lg p-4 border border-gray-100">
                            <h4 class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2">Descripción</h4>
                            <p class="text-sm text-gray-600 leading-relaxed" x-text="selectedItem?.detalles"></p>
                        </div>
                    </template>

                    <!-- Specs Grid -->
                    <div class="grid grid-cols-2 gap-2">
                        <template x-if="selectedItem?.pieza">
                            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                                <span class="text-[10px] text-gray-400 font-medium block mb-0.5">Pieza</span>
                                <span class="text-xs font-semibold text-gray-700" x-text="selectedItem?.pieza"></span>
                            </div>
                        </template>

                        <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                            <span class="text-[10px] text-gray-400 font-medium block mb-0.5">No. Parte</span>
                            <span class="text-xs font-semibold text-gray-700" x-text="selectedItem?.numPart || selectedItem?.idSrc || 'N/A'"></span>
                        </div>

                        <template x-if="selectedItem?.localidad">
                            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                                <span class="text-[10px] text-gray-400 font-medium block mb-0.5">Ubicación</span>
                                <span class="text-xs font-semibold text-gray-700" x-text="selectedItem?.localidad"></span>
                            </div>
                        </template>

                        <template x-if="selectedItem?.anioInicio && selectedItem?.anioInicio > 0">
                            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                                <span class="text-[10px] text-gray-400 font-medium block mb-0.5">Año</span>
                                <span class="text-xs font-semibold text-gray-700">
                                    <span x-text="selectedItem?.anioInicio"></span><span x-show="selectedItem?.anioFin && selectedItem?.anioFin < 9999" x-text="' - ' + selectedItem?.anioFin"></span>
                                </span>
                            </div>
                        </template>

                        <template x-if="selectedItem?.lado && selectedItem?.lado !== 'A'">
                            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                                <span class="text-[10px] text-gray-400 font-medium block mb-0.5">Lado</span>
                                <span class="text-xs font-semibold text-gray-700" x-text="selectedItem?.lado"></span>
                            </div>
                        </template>

                        <template x-if="selectedItem?.poss && selectedItem?.poss !== 'A'">
                            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                                <span class="text-[10px] text-gray-400 font-medium block mb-0.5">Posición</span>
                                <span class="text-xs font-semibold text-gray-700" x-text="selectedItem?.poss"></span>
                            </div>
                        </template>
                    </div>

                    <!-- Mercado Libre Link -->
                    <template x-if="selectedItem?.linkSr && String(selectedItem?.linkSr).includes('mercadolibre')">
                        <div class="mt-4">
                            <a :href="selectedItem.linkSr" target="_blank" class="text-blue-600 hover:text-blue-800 text-sm font-bold no-underline flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                Adquiri por MErcado Libre
                            </a>
                        </div>
                    </template>

                    <!-- Trust badges -->
                    <div class="flex gap-2">
                        <div class="flex-1 flex items-center gap-2 bg-gray-50 rounded-lg p-3 border border-gray-100">
                            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                            <div>
                                <span class="text-[10px] text-gray-400 block">Garantía</span>
                                <span class="text-[11px] font-semibold text-gray-700">7 días</span>
                            </div>
                        </div>
                        <div class="flex-1 flex items-center gap-2 bg-gray-50 rounded-lg p-3 border border-gray-100">
                            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"></path></svg>
                            <div>
                                <span class="text-[10px] text-gray-400 block">Envío</span>
                                <span class="text-[11px] font-semibold text-gray-700">Todo México</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
function shopModalLogic() {
    return {
        activeImg: '',
        rotation: 0,
        isZoomed: false,
        zX: 50,
        zY: 50,
        onItemSelected(v) {
            this.activeImg = v ? v.imgBig : '';
            this.rotation = 0;
            this.isZoomed = false;
            this.zX = 50;
            this.zY = 50;
        },
        openGalleryManual(activeImg, pictures, pathImg) {
            let dataSource = [];
            
            if (Array.isArray(pictures) && pictures.length > 0) {
                dataSource = pictures.map(pic => {
                    const src = (pic.startsWith('http') || pic.startsWith('/') || pic.startsWith('//')) 
                        ? pic 
                        : (pathImg ? `${pathImg}/${pic}` : pic);
                    return { src, width: 2000, height: 2000 };
                });
            }
            
            let index = dataSource.findIndex(item => item.src === activeImg);
            if (index === -1 && activeImg) {
                dataSource.unshift({ src: activeImg, width: 2000, height: 2000 });
                index = 0;
            }
            
            if (dataSource.length === 0) return;

            const pswp = new PhotoSwipe({
                dataSource: dataSource,
                index: index,
                pswpModule: () => import('https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.esm.js'),
                bgOpacity: 0.98,
                wheelToZoom: true,
                secondaryZoomLevel: 2.5,
                maxZoomLevel: 6,
            });
            pswp.init();
        }
    }
}
</script>
