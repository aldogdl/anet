<div id="modal-pro" 
     x-show="showModal" 
     x-cloak
     x-data="shopModalLogic()"
     x-init="$watch('selectedItem', v => onItemSelected(v))"
     class="fixed inset-0 z-[100] flex items-center justify-center p-3 sm:p-6 overflow-hidden"
     x-transition:enter="transition ease-out duration-200"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100">

    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm z-0" @click="showModal = false"></div>

    <!-- Modal Content -->
    <div class="relative bg-white w-full max-w-5xl max-h-[92vh] rounded-xl shadow-2xl flex flex-col lg:flex-row overflow-hidden z-10"
         x-transition:enter="transition ease-out duration-300 delay-75"
         x-transition:enter-start="opacity-0 translate-y-6 scale-[0.97]"
         x-transition:enter-end="opacity-100 translate-y-0 scale-100">
        
        <!-- Close Button -->
        <button @click="showModal = false" class="absolute top-3 right-3 z-20 p-2 bg-gray-100 hover:bg-red-500 hover:text-white text-gray-400 rounded-lg transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <style>
          .pswp__icn { display: none !important; }
          .pswp__top-bar { display: none !important; }
          .pswp__img { transition: transform 0.3s cubic-bezier(0.33, 1, 0.68, 1) !important; }
          .pswp { z-index: 3000 !important; }
          .pswp__custom-panel { position: absolute !important; bottom: 30px !important; left: 50% !important; transform: translateX(-50%) !important; z-index: 9999 !important; pointer-events: none !important; }
          .pswp__pro-panel { display: flex !important; align-items: center !important; background: rgba(0,0,0,0.8) !important; backdrop-filter: blur(20px) !important; padding: 6px 12px !important; border-radius: 12px !important; gap: 8px !important; pointer-events: auto !important; }
          .pswp__btn-pro { background: transparent !important; border: none !important; width: 40px !important; height: 40px !important; display: flex !important; align-items: center !important; justify-content: center !important; border-radius: 8px !important; transition: all 0.2s !important; cursor: pointer !important; }
          .pswp__btn-pro:hover { background: rgba(255,255,255,0.15) !important; }
          .pswp__divider { width: 1px; height: 20px; background: rgba(255,255,255,0.1); }
        </style>

        <!-- Left: Image Gallery -->
        <div class="w-full lg:w-[55%] bg-[#fafafa] flex flex-col border-r border-gray-100 overflow-hidden">
            <div id="gallery-pro" class="flex-1 flex flex-col h-full overflow-hidden">
                <!-- Main Image -->
                <div class="flex-1 min-h-[250px] sm:min-h-[350px] relative group flex items-center justify-center p-4 sm:p-8">
                    <a :href="activeImg" 
                       id="main-pswp-link"
                       data-pswp-width="1200" 
                       data-pswp-height="1200" 
                       target="_blank"
                       class="flex items-center justify-center cursor-zoom-in w-full h-full">
                        <img :src="activeImg" 
                             :style="`transform: rotate(${rotation}deg)`"
                             class="max-w-full max-h-full w-auto h-auto object-contain transition-transform duration-300"
                             @load="
                                $el.parentElement.setAttribute('data-pswp-width', $el.naturalWidth);
                                $el.parentElement.setAttribute('data-pswp-height', $el.naturalHeight);
                             " />
                    </a>

                    <!-- Rotate button -->
                    <button @click="rotation = (rotation + 90) % 360" 
                            class="absolute bottom-4 left-4 bg-white border border-gray-200 p-2 rounded-lg text-gray-400 hover:text-gray-600 hover:border-gray-300 transition-all shadow-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    </button>

                    <!-- Zoom hint -->
                    <div class="absolute bottom-4 right-4 bg-white/80 backdrop-blur-sm border border-gray-100 px-2.5 py-1 rounded-md text-[10px] text-gray-400 font-medium flex items-center gap-1.5 pointer-events-none">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        Click para zoom
                    </div>
                </div>

                <!-- Thumbnails -->
                <div class="flex gap-2 px-4 pb-4 overflow-x-auto no-scrollbar flex-shrink-0">
                    <template x-for="(pic, index) in selectedItem?.pictures" :key="index">
                        <div class="w-14 h-14 sm:w-16 sm:h-16 flex-shrink-0 rounded-lg border-2 transition-all cursor-pointer overflow-hidden bg-white"
                             :class="activeImg === (selectedItem.pathImg + '/' + pic) ? 'border-primary' : 'border-gray-100 opacity-50 hover:opacity-100'"
                             @click="activeImg = selectedItem.pathImg + '/' + pic; rotation = 0">
                            <img :src="selectedItem.pathImg + '/' + pic" class="w-full h-full object-cover rounded-[5px]" />
                        </div>
                    </template>
                </div>
            </div>
        </div>

        <!-- Right: Details -->
        <div class="w-full lg:w-[45%] flex flex-col overflow-y-auto max-h-[50vh] lg:max-h-none">
            <div class="p-5 sm:p-6 lg:p-8 flex-1">

                <!-- Badges -->
                <div class="flex flex-wrap items-center gap-1.5 mb-3">
                    <span class="text-[10px] font-medium text-gray-400 bg-gray-100 px-2 py-0.5 rounded" x-text="'ID: ' + selectedItem?.id"></span>
                    <span class="text-[10px] font-medium text-gray-400 bg-gray-100 px-2 py-0.5 rounded" x-text="'SKU: ' + selectedItem?.sku"></span>
                    <template x-if="selectedItem?.numPart">
                        <span class="text-[10px] font-medium text-primary bg-primary/10 px-2 py-0.5 rounded" x-text="'N/P: ' + selectedItem?.numPart"></span>
                    </template>
                </div>

                <!-- Title -->
                <h2 class="text-xl sm:text-2xl font-bold text-gray-900 leading-tight tracking-tight mb-1" x-text="selectedItem?.title"></h2>
                
                <!-- Brand / Model -->
                <p class="text-sm text-gray-400 font-medium mb-5" x-show="selectedItem?.mk || selectedItem?.md">
                    <span x-text="selectedItem?.mk"></span>
                    <span x-show="selectedItem?.md"> · <span x-text="selectedItem?.md"></span></span>
                    <span x-show="selectedItem?.anioInicio && selectedItem?.anioInicio > 0">
                        · <span x-text="selectedItem?.anioInicio"></span><span x-show="selectedItem?.anioFin && selectedItem?.anioFin < 9999" x-text="'-' + selectedItem?.anioFin"></span>
                    </span>
                </p>

                <!-- Price -->
                <div class="flex items-baseline gap-2 mb-6">
                    <span class="text-3xl font-bold text-gray-900 tracking-tight" x-text="'$' + Number(selectedItem?.price).toLocaleString('es-MX', {minimumFractionDigits: 2})"></span>
                    <span class="text-xs text-gray-400 font-medium">MXN</span>
                </div>

                <!-- Technical Details Grid -->
                <div class="space-y-4 mb-6">
                    <!-- Description -->
                    <template x-if="selectedItem?.detalles">
                        <div class="bg-gray-50 rounded-lg p-4 border border-gray-100">
                            <h4 class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2">Descripción</h4>
                            <p class="text-sm text-gray-600 leading-relaxed" x-text="selectedItem?.detalles"></p>
                        </div>
                    </template>

                    <!-- Specs Grid -->
                    <div class="grid grid-cols-2 gap-2">
                        <template x-if="selectedItem?.pieza">
                            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                                <span class="text-[10px] text-gray-400 font-medium block mb-0.5">Pieza</span>
                                <span class="text-xs font-semibold text-gray-700" x-text="selectedItem?.pieza"></span>
                            </div>
                        </template>
                        <template x-if="selectedItem?.mk">
                            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                                <span class="text-[10px] text-gray-400 font-medium block mb-0.5">Marca</span>
                                <span class="text-xs font-semibold text-gray-700" x-text="selectedItem?.mk"></span>
                            </div>
                        </template>
                        <template x-if="selectedItem?.md">
                            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                                <span class="text-[10px] text-gray-400 font-medium block mb-0.5">Modelo</span>
                                <span class="text-xs font-semibold text-gray-700" x-text="selectedItem?.md"></span>
                            </div>
                        </template>
                        <template x-if="selectedItem?.anioInicio && selectedItem?.anioInicio > 0">
                            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                                <span class="text-[10px] text-gray-400 font-medium block mb-0.5">Año</span>
                                <span class="text-xs font-semibold text-gray-700">
                                    <span x-text="selectedItem?.anioInicio"></span><span x-show="selectedItem?.anioFin && selectedItem?.anioFin < 9999" x-text="' - ' + selectedItem?.anioFin"></span>
                                </span>
                            </div>
                        </template>
                        <template x-if="selectedItem?.lado && selectedItem?.lado !== 'A'">
                            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                                <span class="text-[10px] text-gray-400 font-medium block mb-0.5">Lado</span>
                                <span class="text-xs font-semibold text-gray-700" x-text="selectedItem?.lado"></span>
                            </div>
                        </template>
                        <template x-if="selectedItem?.poss && selectedItem?.poss !== 'A'">
                            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                                <span class="text-[10px] text-gray-400 font-medium block mb-0.5">Posición</span>
                                <span class="text-xs font-semibold text-gray-700" x-text="selectedItem?.poss"></span>
                            </div>
                        </template>
                        <template x-if="selectedItem?.numPart">
                            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                                <span class="text-[10px] text-gray-400 font-medium block mb-0.5">Número de parte</span>
                                <span class="text-xs font-semibold text-gray-700" x-text="selectedItem?.numPart"></span>
                            </div>
                        </template>
                        <template x-if="selectedItem?.localidad">
                            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
                                <span class="text-[10px] text-gray-400 font-medium block mb-0.5">Ubicación</span>
                                <span class="text-xs font-semibold text-gray-700" x-text="selectedItem?.localidad"></span>
                            </div>
                        </template>
                    </div>

                    <!-- Trust badges -->
                    <div class="flex gap-2">
                        <div class="flex-1 flex items-center gap-2 bg-gray-50 rounded-lg p-3 border border-gray-100">
                            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                            <div>
                                <span class="text-[10px] text-gray-400 block">Garantía</span>
                                <span class="text-[11px] font-semibold text-gray-700">7 días</span>
                            </div>
                        </div>
                        <div class="flex-1 flex items-center gap-2 bg-gray-50 rounded-lg p-3 border border-gray-100">
                            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"></path></svg>
                            <div>
                                <span class="text-[10px] text-gray-400 block">Envío</span>
                                <span class="text-[11px] font-semibold text-gray-700">Todo México</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sticky CTA area -->
            <div class="border-t border-gray-100 p-5 sm:p-6 lg:px-8 bg-white flex-shrink-0 space-y-3">
                <!-- Cart buttons -->
                <template x-if="!cartItems[selectedItem?.id]">
                    <button @click="addToCart(selectedItem.id)" class="w-full bg-primary hover:bg-emerald-400 text-dark font-semibold py-3 rounded-lg transition-all flex items-center justify-center gap-2 active:scale-[0.98] text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        Añadir al carrito
                    </button>
                </template>
                <template x-if="cartItems[selectedItem?.id]">
                    <button @click="promptRemove(selectedItem.id)" class="w-full bg-primary/10 hover:bg-primary/20 text-primary font-semibold py-3 rounded-lg transition-all flex items-center justify-center gap-2 active:scale-[0.98] text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                        Quitar del carrito
                    </button>
                </template>
                
                <!-- WhatsApp -->
                <a :href="`https://wa.me/{{ contactPhone|default('') }}?text=` + encodeURIComponent(`Hola, me interesa:\n\n🔧 ${selectedItem?.title}\n💰 $${Number(selectedItem?.price).toLocaleString()}\n📋 ID: ${selectedItem?.id}`)"
                   target="_blank"
                   class="w-full flex items-center justify-center gap-2 py-2.5 rounded-lg border border-gray-200 text-gray-500 hover:border-primary hover:text-primary transition-colors text-xs font-medium">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 0C5.394 0 0 5.394 0 12.031c0 2.115.548 4.17 1.583 5.986L.048 23.518l5.656-1.482a12.002 12.002 0 006.327 1.785h.005c6.634 0 12.029-5.394 12.029-12.031S18.667 0 12.031 0zm0 21.821h-.004a9.986 9.986 0 01-5.088-1.385l-.365-.216-3.782.991.99-3.685-.236-.376a9.986 9.986 0 01-1.526-5.334c0-5.522 4.493-10.017 10.015-10.017 2.675 0 5.188 1.042 7.079 2.934 1.891 1.892 2.932 4.406 2.932 7.081 0 5.524-4.494 10.007-10.014 10.007zm5.493-7.513c-.301-.151-1.785-.882-2.062-.983-.277-.101-.479-.151-.68.151-.202.302-.781.983-.957 1.184-.177.202-.353.227-.654.076-.301-.151-1.275-.47-2.428-1.5-.898-.801-1.503-1.793-1.68-2.095-.177-.302-.019-.465.132-.616.135-.135.301-.353.452-.529.151-.177.202-.302.302-.504.101-.202.05-.378-.025-.529-.076-.151-.68-1.64-.932-2.245-.246-.59-.496-.51-.68-.52-.177-.01-.378-.01-.58-.01-.202 0-.529.076-.806.378-.277.302-1.057 1.033-1.057 2.519s1.083 2.923 1.234 3.125c.151.202 2.13 3.25 5.161 4.557.72.311 1.281.497 1.722.636.723.23 1.381.197 1.902.12.583-.086 1.785-.73 2.036-1.436.252-.705.252-1.309.177-1.436-.076-.126-.277-.202-.578-.353z"></path></svg>
                    Consultar por WhatsApp
                </a>
            </div>
        </div>
    </div>
</div>

<script>
function shopModalLogic() {
    return {
        activeImg: '',
        rotation: 0,
        onItemSelected(v) {
            this.activeImg = v ? v.imgBig : '';
            this.rotation = 0;
            this.$nextTick(() => this.initGallery());
        },
        initGallery() {
            if (window.lightbox) window.lightbox.destroy();
            window.lightbox = new PhotoSwipeLightbox({
                gallery: '#gallery-pro',
                children: 'a',
                pswpModule: () => import('https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.esm.js'),
                initialZoomLevel: 'fit',
                secondaryZoomLevel: 3,
                maxZoomLevel: 10,
            });

            window.lightbox.on('uiRegister', function() {
                window.lightbox.pswp.ui.registerElement({
                    name: 'custom-panel',
                    className: 'pswp__custom-panel',
                    appendTo: 'wrapper',
                    onInit: (el, pswp) => {
                        el.innerHTML = `
                            <div class="pswp__pro-panel">
                                <button class="pswp__btn-pro rotate-btn" title="Rotar">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                                </button>
                                <div class="pswp__divider"></div>
                                <button class="pswp__btn-pro close-pro-btn" title="Cerrar">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="#ff5f57" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                </button>
                            </div>
                        `;

                        el.querySelector('.rotate-btn').onclick = (e) => {
                            e.stopPropagation();
                            const img = pswp.currSlide.container.querySelector('.pswp__img');
                            if (img) {
                                const r = (parseInt(img.dataset.rotation || '0') + 90) % 360;
                                img.style.transform = `rotate(${r}deg)`;
                                img.dataset.rotation = r;
                            }
                        };
                        el.querySelector('.close-pro-btn').onclick = (e) => {
                            e.stopPropagation();
                            pswp.close();
                        };
                    }
                });
            });

            window.lightbox.on('bindEvents', () => {
                const pswp = window.lightbox.pswp;
                pswp.events.add(pswp.scrollWrap, 'wheel', (e) => {
                    e.preventDefault();
                    const zoomFactor = e.deltaY < 0 ? 1.3 : 0.7;
                    pswp.currSlide.zoomTo(pswp.currSlide.zoomLevels.current * zoomFactor, { x: e.clientX, y: e.clientY }, 250, true);
                });
            });

            window.lightbox.init();
        }
    }
}
</script>
