<div id="modal-pro" 
     x-show="showModal" 
     x-cloak
     x-data="shopModalLogic()"
     x-init="$watch('selectedItem', v => onItemSelected(v))"
     class="fixed inset-0 z-[100] flex items-center justify-center p-4 lg:p-12 overflow-hidden"
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100">
    
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-xl z-0" @click="showModal = false"></div>

    <!-- Modal Content -->
    <div class="relative bg-[#111b21] w-full max-w-7xl h-full max-h-[900px] rounded-[3rem] shadow-2xl flex flex-col lg:flex-row overflow-hidden border border-white/5 z-10"
         x-transition:enter="transition ease-out duration-500 delay-100"
         x-transition:enter-start="opacity-0 translate-y-12 scale-95"
         x-transition:enter-end="opacity-100 translate-y-0 scale-100">
        
        <!-- Close Button (Main Modal) -->
        <button @click="showModal = false" class="absolute top-6 right-6 z-10 p-4 bg-white/5 hover:bg-red-500 hover:text-white rounded-2xl transition-all shadow-xl group border border-white/5">
            <svg class="w-6 h-6 group-hover:rotate-90 transition-transform text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <style>
          .pswp__icn { display: none !important; }
          .pswp__top-bar { display: none !important; }
          .pswp__img { transition: transform 0.3s cubic-bezier(0.33, 1, 0.68, 1) !important; }
          .pswp { z-index: 3000 !important; }
          
          /* Panel Nativo */
          .pswp__custom-panel {
            position: absolute !important;
            bottom: 40px !important;
            left: 50% !important;
            transform: translateX(-50%) !important;
            z-index: 9999 !important;
            width: auto !important;
            height: auto !important;
            pointer-events: none !important;
          }
          .pswp__pro-panel {
            display: flex !important;
            align-items: center !important;
            background: rgba(11, 20, 26, 0.95) !important;
            backdrop-filter: blur(25px) !important;
            padding: 8px 16px !important;
            border-radius: 32px !important;
            border: 1px solid rgba(255,255,255,0.2) !important;
            box-shadow: 0 30px 80px rgba(0,0,0,0.9) !important;
            gap: 10px !important;
            pointer-events: auto !important;
          }
          .pswp__btn-pro {
            background: transparent !important;
            border: none !important;
            width: 50px !important;
            height: 50px !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            border-radius: 18px !important;
            transition: all 0.2s !important;
            cursor: pointer !important;
          }
          .pswp__btn-pro:hover { background: rgba(255,255,255,0.15) !important; transform: scale(1.1) !important; }
          .pswp__divider { width: 1px; height: 24px; background: rgba(255,255,255,0.1); }
        </style>

        <!-- Left: Image Gallery -->
        <div class="w-full lg:w-3/5 bg-black/10 flex flex-col p-4 lg:p-8 border-r border-white/5 overflow-hidden">
            <div id="gallery-pro" class="flex-1 flex flex-col gap-8 h-full overflow-hidden">
                <!-- Main Preview Image -->
                <div class="flex-1 rounded-[2.5rem] bg-[#0b141a] border border-white/5 shadow-inner overflow-hidden relative group">
                    <a :href="activeImg" 
                       id="main-pswp-link"
                       data-pswp-width="1200" 
                       data-pswp-height="1200" 
                       target="_blank"
                       class="w-full h-full flex items-center justify-center p-4 lg:p-8 cursor-zoom-in">
                        <img :src="activeImg" 
                             :style="`transform: rotate(${rotation}deg)`"
                             class="max-w-full max-h-full w-auto h-auto object-contain transition-transform duration-500 group-hover:scale-110"
                             @load="
                                $el.parentElement.setAttribute('data-pswp-width', $el.naturalWidth);
                                $el.parentElement.setAttribute('data-pswp-height', $el.naturalHeight);
                             " />
                    </a>

                    <div class="absolute bottom-6 left-6 flex gap-3">
                        <button @click="rotation = (rotation + 90) % 360" 
                                class="bg-black/60 backdrop-blur-xl p-4 rounded-2xl border border-white/10 text-white hover:bg-[#25d366] hover:scale-110 transition-all shadow-2xl group/rot">
                            <svg class="w-6 h-6 group-hover/rot:rotate-90 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                        </button>
                    </div>

                    <div class="absolute bottom-6 right-6 bg-black/60 backdrop-blur-md px-5 py-2.5 rounded-2xl text-[10px] font-black uppercase tracking-widest text-[#25d366] flex items-center gap-2 border border-white/10 pointer-events-none shadow-xl">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        Click para Zoom HD
                    </div>
                </div>

                <!-- Thumbnails -->
                <div class="flex gap-4 overflow-x-auto pb-4 no-scrollbar">
                    <template x-for="(pic, index) in selectedItem?.pictures" :key="index">
                        <div class="w-24 h-24 flex-shrink-0 rounded-2xl border-2 transition-all cursor-pointer overflow-hidden p-1 bg-[#0b141a] shadow-sm"
                             :class="activeImg === (selectedItem.pathImg + '/' + pic) ? 'border-[#25d366]' : 'border-transparent opacity-40 hover:opacity-100'"
                             @click="activeImg = selectedItem.pathImg + '/' + pic; rotation = 0">
                            <img :src="selectedItem.pathImg + '/' + pic" class="w-full h-full object-contain rounded-xl" />
                        </div>
                    </template>
                </div>
            </div>
        </div>

        <!-- Right: Technical Details -->
        <div class="w-full lg:w-2/5 p-8 lg:p-16 flex flex-col justify-between overflow-y-auto">
            <div>
                <div class="flex items-center gap-2 mb-6">
                    <span class="bg-[#25d366] text-white text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest shadow-lg shadow-[#25d366]/20" x-text="'SKU: ' + selectedItem?.sku"></span>
                </div>

                <h2 class="text-3xl lg:text-3xl font-black text-white leading-tight tracking-tight mb-4" x-text="selectedItem?.title"></h2>
                
                <div class="flex items-baseline gap-2 mb-8">
                    <span class="text-4xl font-black text-[#25d366] italic" x-text="'$' + Number(selectedItem?.price).toLocaleString()"></span>
                    <span class="text-sm font-bold text-white/45 uppercase tracking-widest">MXN + Envío</span>
                </div>

                <div class="space-y-6 mb-12">
                    <div class="bg-[#0b141a] p-6 rounded-3xl border border-white/5">
                        <h4 class="text-[10px] font-black text-[#25d366] uppercase tracking-widest mb-3">Descripción Técnica</h4>
                        <p class="text-sm text-slate-300 leading-relaxed font-medium" x-text="selectedItem?.detalles"></p>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="p-4 bg-[#0b141a] border border-white/5 rounded-2xl">
                            <span class="text-[9px] font-black text-white/45 uppercase tracking-widest block mb-1">Garantía</span>
                            <span class="text-xs font-bold text-white uppercase">7 Días Naturales</span>
                        </div>
                        <div class="p-4 bg-[#0b141a] border border-white/5 rounded-2xl">
                            <span class="text-[9px] font-black text-white/45 uppercase tracking-widest block mb-1">Envío</span>
                            <span class="text-xs font-bold text-white uppercase">Todo México</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex flex-col gap-4">
                <template x-if="!cartItems[selectedItem?.id]">
                    <button @click="addToCart(selectedItem.id)" class="w-full bg-[#25d366] hover:bg-emerald-400 text-white font-black py-5 rounded-[1.5rem] shadow-xl shadow-[#25d366]/20 transition-all flex items-center justify-center gap-3 active:scale-95 group">
                        <svg class="w-6 h-6 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        AÑADIR AL CARRITO
                    </button>
                </template>
                <template x-if="cartItems[selectedItem?.id]">
                    <button @click="promptRemove(selectedItem.id)" class="w-full bg-[#25d366]/20 hover:bg-[#25d366]/30 text-[#25d366] font-black py-5 rounded-[1.5rem] shadow-sm transition-all flex items-center justify-center gap-3 active:scale-95 group">
                        <svg class="w-6 h-6 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                        QUITAR DEL CARRITO
                    </button>
                </template>
                
                <div class="bg-[#0b141a] p-6 rounded-[1.5rem] border border-white/5 flex flex-col items-center justify-center gap-4 text-center mt-2 group relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-[#25d366]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
                    
                    <div class="text-[#25d366] flex items-center gap-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 0C5.394 0 0 5.394 0 12.031c0 2.115.548 4.17 1.583 5.986L.048 23.518l5.656-1.482a12.002 12.002 0 006.327 1.785h.005c6.634 0 12.029-5.394 12.029-12.031S18.667 0 12.031 0zm0 21.821h-.004a9.986 9.986 0 01-5.088-1.385l-.365-.216-3.782.991.99-3.685-.236-.376a9.986 9.986 0 01-1.526-5.334c0-5.522 4.493-10.017 10.015-10.017 2.675 0 5.188 1.042 7.079 2.934 1.891 1.892 2.932 4.406 2.932 7.081 0 5.524-4.494 10.007-10.014 10.007zm5.493-7.513c-.301-.151-1.785-.882-2.062-.983-.277-.101-.479-.151-.68.151-.202.302-.781.983-.957 1.184-.177.202-.353.227-.654.076-.301-.151-1.275-.47-2.428-1.5-.898-.801-1.503-1.793-1.68-2.095-.177-.302-.019-.465.132-.616.135-.135.301-.353.452-.529.151-.177.202-.302.302-.504.101-.202.05-.378-.025-.529-.076-.151-.68-1.64-.932-2.245-.246-.59-.496-.51-.68-.52-.177-.01-.378-.01-.58-.01-.202 0-.529.076-.806.378-.277.302-1.057 1.033-1.057 2.519s1.083 2.923 1.234 3.125c.151.202 2.13 3.25 5.161 4.557.72.311 1.281.497 1.722.636.723.23 1.381.197 1.902.12.583-.086 1.785-.73 2.036-1.436.252-.705.252-1.309.177-1.436-.076-.126-.277-.202-.578-.353z"></path></svg>
                    </div>
                    <span class="font-black tracking-widest uppercase text-xs text-[#25d366]">Atención por WhatsApp</span>

                    <div class="bg-white p-2 rounded-xl w-32 h-32 flex items-center justify-center shadow-lg shadow-black/50 group-hover:scale-105 transition-transform duration-500">
                        <img :src="`https://api.qrserver.com/v1/create-qr-code/?size=150x150&margin=1&color=0b141a&data=` + encodeURIComponent(`https://wa.me/{{ contactPhone|default('') }}?text=Hola,%20me%20interesa%20información%20del%20artículo:\n\n🚘%20${selectedItem?.title}`)" 
                             alt="Código QR WhatsApp" class="w-full h-full object-contain mix-blend-multiply" />
                    </div>

                    <p class="text-[10px] text-slate-400 font-medium leading-relaxed max-w-[80%]">
                        Escanea este código con la cámara de tu celular para consultar existencias o dudas.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function shopModalLogic() {
    return {
        activeImg: '',
        rotation: 0,
        onItemSelected(v) {
            this.activeImg = v ? v.imgBig : '';
            this.rotation = 0;
            this.$nextTick(() => this.initGallery());
        },
        initGallery() {
            if (window.lightbox) window.lightbox.destroy();
            window.lightbox = new PhotoSwipeLightbox({
                gallery: '#gallery-pro',
                children: 'a',
                pswpModule: () => import('https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.esm.js'),
                initialZoomLevel: 'fit',
                secondaryZoomLevel: 3,
                maxZoomLevel: 10,
            });

            window.lightbox.on('uiRegister', function() {
                window.lightbox.pswp.ui.registerElement({
                    name: 'custom-panel',
                    className: 'pswp__custom-panel',
                    appendTo: 'wrapper',
                    onInit: (el, pswp) => {
                        el.innerHTML = `
                            <div class="pswp__pro-panel">
                                <button class="pswp__btn-pro rotate-btn" title="Rotar">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                                </button>
                                <div class="pswp__divider"></div>
                                <button class="pswp__btn-pro close-pro-btn" title="Cerrar">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="#ff5f57" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                </button>
                            </div>
                        `;

                        el.querySelector('.rotate-btn').onclick = (e) => {
                            e.stopPropagation();
                            const img = pswp.currSlide.container.querySelector('.pswp__img');
                            if (img) {
                                const r = (parseInt(img.dataset.rotation || '0') + 90) % 360;
                                img.style.transform = `rotate(${r}deg)`;
                                img.dataset.rotation = r;
                            }
                        };
                        el.querySelector('.close-pro-btn').onclick = (e) => {
                            e.stopPropagation();
                            pswp.close();
                        };
                    }
                });
            });

            window.lightbox.on('bindEvents', () => {
                const pswp = window.lightbox.pswp;
                pswp.events.add(pswp.scrollWrap, 'wheel', (e) => {
                    e.preventDefault();
                    const zoomFactor = e.deltaY < 0 ? 1.3 : 0.7;
                    pswp.currSlide.zoomTo(pswp.currSlide.zoomLevels.current * zoomFactor, { x: e.clientX, y: e.clientY }, 250, true);
                });
            });

            window.lightbox.init();
        }
    }
}
</script>
