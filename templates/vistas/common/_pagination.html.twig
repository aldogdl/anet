{# templates/vistas/common/_pagination.html.twig #}
{# 
    Paginador Pro - Diseñado para impactar
    Variables:
    - pagesCount: Total de páginas
    - currentPage: Página actual
    - dark: true/false
#}

{% set dark = dark|default(false) %}
{% set adj = 3 %} {# Páginas adyacentes a mostrar #}

{% if pagesCount > 1 %}
<div class="mt-12 mb-8 flex flex-col items-center gap-4">
    <!-- Contador de estado -->
    <div class="text-[10px] font-semibold uppercase tracking-wider {{ dark ? 'text-white/40' : 'text-slate-400' }}">
        Página <span class="{{ dark ? 'text-[#0e7045]' : 'text-[#0e7045]' }} font-bold">{{ currentPage }}</span> de {{ pagesCount }}
    </div>

    <nav class="inline-flex items-center p-1 {{ dark ? 'bg-white/5 border-white/5' : 'bg-white border-slate-200/80 shadow-sm' }} border rounded-xl gap-1">
        
        <!-- Botón Primera -->
        <button @click="applyFilter({page: 1})" 
                :disabled="currentFilters.page == 1"
                title="Primera página"
                class="group relative w-8 h-8 flex items-center justify-center rounded-lg transition-all duration-200 {{ dark ? 'text-white/70 hover:text-[#0e7045]' : 'text-slate-500 hover:text-[#0e7045]' }} disabled:opacity-10 disabled:cursor-not-allowed">
            <svg class="w-4 h-4 group-hover:scale-105 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path></svg>
        </button>

        <!-- Botón Anterior -->
        <button @click="applyFilter({page: Math.max(1, currentFilters.page - 1)})"
                :disabled="currentFilters.page == 1"
                class="w-8 h-8 flex items-center justify-center rounded-lg transition-all duration-200 {{ dark ? 'text-white/70 hover:text-white hover:bg-white/10' : 'text-slate-500 hover:text-slate-800 hover:bg-slate-50' }} disabled:opacity-10 disabled:cursor-not-allowed mr-0.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg>
        </button>

        <!-- Contenedor de Números -->
        <div class="flex items-center gap-1">
            {% for i in 1..pagesCount %}
                {% if i == 1 or i == pagesCount or (i >= currentPage - adj and i <= currentPage + adj) %}
                    {% set isFar = (i < currentPage - 1 or i > currentPage + 1) and (i != 1 and i != pagesCount) %}
                    <button @click="applyFilter({page: {{ i }}})" 
                            class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-lg text-xs font-semibold transition-all duration-200 overflow-hidden group
                            {{ isFar ? 'hidden md:flex' : 'flex' }}
                            {{ i == currentPage ? 
                                'bg-[#0e7045] text-white shadow-sm font-bold z-10' : 
                                (dark ? 'text-white/70 hover:text-white hover:bg-white/10' : 'text-slate-600 hover:text-slate-800 hover:bg-slate-50') }}">
                        <span class="relative z-10">{{ i }}</span>
                    </button>
                {% elseif (i == 2 and currentPage > adj + 2) or (i == pagesCount - 1 and currentPage < pagesCount - adj - 1) %}
                    <div class="w-6 flex flex-col items-center justify-center gap-0.5 opacity-30">
                        <span class="w-0.5 h-0.5 rounded-full {{ dark ? 'bg-white' : 'bg-slate-400' }}"></span>
                        <span class="w-0.5 h-0.5 rounded-full {{ dark ? 'bg-white' : 'bg-slate-400' }}"></span>
                        <span class="w-0.5 h-0.5 rounded-full {{ dark ? 'bg-white' : 'bg-slate-400' }}"></span>
                    </div>
                {% endif %}
            {% endfor %}
        </div>

        <!-- Botón Siguiente -->
        <button @click="applyFilter({page: Math.min({{ pagesCount }}, currentFilters.page + 1)})"
                :disabled="currentFilters.page == {{ pagesCount }}"
                class="w-8 h-8 flex items-center justify-center rounded-lg transition-all duration-200 {{ dark ? 'text-white/70 hover:text-white hover:bg-white/10' : 'text-slate-500 hover:text-slate-800 hover:bg-slate-50' }} disabled:opacity-10 disabled:cursor-not-allowed ml-0.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
        </button>

        <!-- Botón Última -->
        <button @click="applyFilter({page: {{ pagesCount }}})" 
                :disabled="currentFilters.page == {{ pagesCount }}"
                title="Última página"
                class="group relative w-8 h-8 flex items-center justify-center rounded-lg transition-all duration-200 {{ dark ? 'text-white/70 hover:text-[#0e7045]' : 'text-slate-500 hover:text-[#0e7045]' }} disabled:opacity-10 disabled:cursor-not-allowed">
            <svg class="w-4 h-4 group-hover:scale-105 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 5l7 7-7 7M5 5l7 7-7 7"></path></svg>
        </button>
    </nav>

    <!-- Barra de progreso sutil -->
    <div class="w-48 h-0.5 {{ dark ? 'bg-white/5' : 'bg-slate-100' }} rounded-full overflow-hidden">
        <div class="h-full bg-[#0e7045] transition-all duration-500 ease-out"
             style="width: {{ (currentPage / pagesCount * 100)|round }}%"></div>
    </div>
</div>
{% endif %}
