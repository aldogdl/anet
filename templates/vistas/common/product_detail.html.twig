{% extends 'base.html.twig' %}
{% import 'vistas/common/_product_helpers.html.twig' as product %}

{% block title %}{{ item.fuente }} | {{ storeName|default('YonkEros') }}{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.css">
{% endblock %}

{% block body %}
{% set mainImg = product.mainImg(item) %}
{% set extras = item.extras|default({}) %}
{% set pictures = extras.pictures|default([]) %}
{% set pathImg = product.extra(item, 'pathImg', '') %}
{% set mkName = product.extraFirst(item, 'mk') %}
{% set mdName = product.extraFirst(item, 'md') %}
{% set numPart = product.extraFirst(item, 'numPart') %}
{% set localidad = product.extraFirst(item, 'localidad') %}
{% set idSrc = product.extra(item, 'idSrc', '') %}
{% set linkSr = product.extra(item, 'linkSr', '') %}
{% set pTitle = product.productTitle(item) %}
{% set firstPic = (extras.pictures|default([]))|first %}
{% set imgBig = product.imgUrl(item, firstPic) %}

{% set modalData = {
    id: item.id,
    title: pTitle,
    price: item.price,
    thumb: mainImg,
    imgBig: imgBig,
    detalles: item.detalles|default('Sin detalles adicionales.'),
    sku: item.iku|default('N/A'),
    brand: item.mrkId,
    model: item.mdlId,
    mk: mkName,
    md: mdName,
    pieza: item.pieza|default(''),
    numPart: numPart|default(idSrc|default('')),
    localidad: localidad,
    anioInicio: item.anioInicio|default(0),
    anioFin: item.anioFin|default(9999),
    lado: (item.lado|default('A') == 'A') ? '' : (item.lado|lp_decode(item.pieza|default(''))),
    poss: (item.poss|default('A') == 'A') ? '' : (item.poss|lp_decode(item.pieza|default(''))),
    pictures: pictures,
    pathImg: pathImg,
    idSrc: idSrc,
    linkSr: linkSr
} %}

<div class="min-h-screen bg-[#fafafa] flex flex-col font-sans antialiased"
     x-data="shopModalLogic({{ modalData|json_encode|e('html_attr') }})">

  <!-- Product Detail -->
  <main class="max-w-5xl mx-auto w-full px-4 sm:px-6 py-4 flex-1 flex items-center justify-center">
    <div class="bg-white rounded-xl border border-gray-100 overflow-hidden flex flex-col lg:flex-row shadow-lg w-full">
         {% include 'vistas/common/_product_detail_body.html.twig' with {'isModal': false} %}
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-gray-50 border-t border-gray-100 py-6 mt-auto">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
        <a href="{{ path('app_shop', { template: 'shop', slug: item.slug|default('demo') }) }}" class="text-xs font-bold text-slate-700 hover:text-emerald-700 transition-colors">
            {{ storeName|default('YonkEros') }} · © {{ 'now'|date('Y') }}
        </a>
    </div>
  </footer>
</div>
{% endblock %}

{% block javascripts %}
<script type="module">
    import PhotoSwipeLightbox from 'https://unpkg.com/photoswipe@5.4.3/dist/photoswipe-lightbox.esm.js';
    import PhotoSwipe from 'https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.esm.js';
    window.PhotoSwipe = PhotoSwipe;
</script>
<script>
    window.contactPhone = "{{ contactPhone }}";

    function shopModalLogic(initialItem = null) {
        const data = {
            activeImg: '',
            rotation: 0,
            isZoomed: false,
            zX: 50,
            zY: 50,
            isTouchDevice: 'ontouchstart' in window || navigator.maxTouchPoints > 0,
            contactPhone: window.contactPhone,
            init() {
                if (this.selectedItem) {
                    this.activeImg = this.selectedItem.imgBig;
                }
            },
            onItemSelected(v) {
                this.activeImg = v ? v.imgBig : '';
                this.rotation = 0;
                this.isZoomed = false;
                this.zX = 50;
                this.zY = 50;
            },
            openGalleryManual(activeImg, pictures, pathImg) {
                let dataSource = [];
                
                if (Array.isArray(pictures) && pictures.length > 0) {
                    dataSource = pictures.map(pic => {
                        const src = (pic.startsWith('http') || pic.startsWith('/') || pic.startsWith('//')) 
                            ? pic 
                            : (pathImg ? `${pathImg}/${pic}` : pic);
                        return { src, width: 2000, height: 2000 };
                    });
                }
                
                let index = dataSource.findIndex(item => item.src === activeImg);
                if (index === -1 && activeImg) {
                    dataSource.unshift({ src: activeImg, width: 2000, height: 2000 });
                    index = 0;
                }
                
                if (dataSource.length === 0) return;

                const pswp = new PhotoSwipe({
                    dataSource: dataSource,
                    index: index,
                    pswpModule: () => import('https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.esm.js'),
                    bgOpacity: 0.98,
                    wheelToZoom: true,
                    secondaryZoomLevel: 2.5,
                    maxZoomLevel: 6,
                });

                pswp.on('gettingData', (e) => {
                     const currSlide = e.data;
                     if (currSlide.width === 2000 && currSlide.height === 2000) {
                         const img = new Image();
                         img.src = currSlide.src;
                         img.onload = () => {
                             currSlide.width = img.naturalWidth;
                             currSlide.height = img.naturalHeight;
                             pswp.refreshSlideContent(e.index);
                         };
                     }
                 });
                 
                pswp.init();
            },
            shareProduct() {
                const shareUrl = this.selectedItem?.detailUrl 
                    ? (window.location.origin + this.selectedItem.detailUrl.trim()) 
                    : window.location.href;
                
                const title = this.selectedItem?.title || 'Refacción de Auto';
                const text = `Mira esta refacción: ${title} en Mi Shop.\n\n${shareUrl}`;

                const showNotification = (msg) => {
                    const toast = document.createElement('div');
                    toast.className = 'fixed bottom-8 left-1/2 -translate-x-1/2 z-[3000] bg-slate-900 text-white px-6 py-3 rounded-xl shadow-2xl flex items-center gap-3 border border-white/10 text-xs font-bold uppercase tracking-wider transition-all duration-300 transform opacity-0 translate-y-4';
                    toast.innerHTML = `
                        <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center flex-shrink-0">
                            <svg class="w-3 h-3 text-slate-900" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <span>${msg}</span>
                    `;
                    document.body.appendChild(toast);
                    toast.offsetHeight; // force reflow
                    toast.classList.remove('opacity-0', 'translate-y-4');
                    setTimeout(() => {
                        toast.classList.add('opacity-0', 'translate-y-4');
                        setTimeout(() => toast.remove(), 300);
                    }, 2500);
                };

                const shareData = {
                    title: title,
                    text: text
                };

                if (navigator.share) {
                    const imageUrl = this.activeImg || this.selectedItem?.imgBig;
                    
                    if (imageUrl && navigator.canShare) {
                        const shareWithImage = async () => {
                            try {
                                const response = await fetch(imageUrl);
                                const blob = await response.blob();
                                let mimeType = blob.type || 'image/jpeg';
                                let extension = mimeType.split('/')[1] || 'jpg';
                                if (extension === 'jpeg') extension = 'jpg';
                                
                                const file = new File([blob], `refaccion.${extension}`, { type: mimeType });
                                
                                if (navigator.canShare({ files: [file] })) {
                                    shareData.files = [file];
                                }
                            } catch (err) {
                                console.warn('No se pudo descargar la imagen para compartir (CORS o red). Compartiendo solo texto.', err);
                            }
                            return navigator.share(shareData);
                        };

                        shareWithImage().catch(err => {
                            console.log('Compartido cancelado o fallido', err);
                        });
                    } else {
                        navigator.share(shareData).catch(err => {
                            console.log('Compartido cancelado o fallido', err);
                        });
                    }
                } else {
                    navigator.clipboard.writeText(shareUrl).then(() => {
                        showNotification('Enlace copiado al portapapeles');
                    }).catch(err => {
                        console.error('Error al copiar enlace', err);
                        alert('No se pudo copiar el enlace automáticamente.');
                    });
                }
            }
        };

        if (initialItem) {
            data.selectedItem = initialItem;
        }

        return data;
    }
</script>
{% endblock %}
