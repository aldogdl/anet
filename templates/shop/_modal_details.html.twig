<div x-show="modalOpen" 
     class="fixed inset-0 z-50 flex items-center justify-center p-4 lg:p-12 overflow-hidden" 
     x-cloak
     @keydown.escape.window="modalOpen = false">
    
    <!-- Backdrop -->
    <div x-show="modalOpen" 
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="absolute inset-0 bg-darker/95 backdrop-blur-md" 
         @click="modalOpen = false"></div>

    <!-- Modal Content -->
    <div x-show="modalOpen" 
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 scale-95 translate-y-8"
         x-transition:enter-end="opacity-100 scale-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 scale-100 translate-y-0"
         x-transition:leave-end="opacity-0 scale-95 translate-y-8"
         class="relative w-full max-w-6xl bg-slate-900 rounded-[3rem] overflow-hidden shadow-2xl border border-slate-800 flex flex-col lg:flex-row max-h-[90vh]">
        
        <!-- Close Button -->
        <button @click="modalOpen = false" class="absolute top-6 right-6 z-50 p-3 bg-slate-800/50 hover:bg-red-500/20 hover:text-red-500 rounded-full backdrop-blur-md transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <!-- Left Column: Gallery -->
        <div class="w-full lg:w-3/5 bg-darker p-4 lg:p-12 flex flex-col gap-6 overflow-y-auto">
            <!-- Main Image with Zoom -->
            <div class="relative aspect-square rounded-[2rem] overflow-hidden bg-slate-900 border border-slate-800 group cursor-zoom-in">
                <img :src="selectedItem?.imgBig" 
                     class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-150 origin-center" 
                     id="zoom-image">
            </div>
            
            <!-- Thumbnails Horizontal Scroll -->
            <div class="flex gap-4 overflow-x-auto pb-4 px-2 no-scrollbar">
                <template x-for="i in 4" :key="i">
                    <div class="w-24 h-24 flex-shrink-0 rounded-2xl border-2 border-primary overflow-hidden cursor-pointer opacity-100 transition-all hover:opacity-100">
                         <img :src="selectedItem?.thumb" class="w-full h-full object-cover">
                    </div>
                </template>
                <!-- Placeholder para más fotos si existieran -->
            </div>
        </div>

        <!-- Right Column: Info -->
        <div class="w-full lg:w-2/5 p-8 lg:p-12 flex flex-col overflow-y-auto bg-slate-900">
            <div class="flex-1">
                <nav class="flex gap-2 text-[10px] font-bold text-primary uppercase tracking-widest mb-4">
                    <span x-text="'Marca ' + selectedItem?.brand"></span>
                    <span class="text-slate-600">•</span>
                    <span x-text="'Modelo ' + selectedItem?.model"></span>
                </nav>
                
                <h2 class="text-3xl lg:text-4xl font-black text-white leading-tight italic" x-text="selectedItem?.title"></h2>
                
                <div class="mt-6 flex items-baseline gap-4">
                    <span class="text-4xl font-black text-primary" x-text="'$' + Number(selectedItem?.price).toLocaleString('es-MX', {minimumFractionDigits: 2})"></span>
                    <span class="text-slate-500 text-sm">IVA Incluido</span>
                </div>

                <div class="mt-8 p-6 bg-darker rounded-3xl border border-slate-800">
                    <h4 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3">Descripción y Detalles</h4>
                    <p class="text-slate-300 text-sm leading-relaxed" x-text="selectedItem?.detalles"></p>
                    
                    <div class="mt-6 grid grid-cols-2 gap-4">
                        <div class="bg-slate-900 p-3 rounded-2xl border border-slate-800">
                            <span class="block text-[10px] text-slate-500 uppercase font-bold">Estado</span>
                            <span class="text-xs text-white font-medium">Original / Usado</span>
                        </div>
                        <div class="bg-slate-900 p-3 rounded-2xl border border-slate-800">
                            <span class="block text-[10px] text-slate-500 uppercase font-bold">SKU</span>
                            <span class="text-xs text-white font-medium" x-text="selectedItem?.sku"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="mt-12 flex flex-col gap-4">
                <button @click="addToCart(selectedItem.id)" 
                        class="w-full bg-primary hover:bg-emerald-500 text-darker font-black py-5 rounded-3xl transition-all shadow-xl shadow-primary/20 flex items-center justify-center gap-3 active:scale-95">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                    AÑADIR AL CARRITO
                </button>
                
                <button class="w-full bg-slate-800 hover:bg-slate-700 text-white font-bold py-5 rounded-3xl transition-all flex items-center justify-center gap-3">
                    <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                    PREGUNTAR POR WHATSAPP
                </button>
            </div>
        </div>
    </div>
</div>
