{% set extras = item.extras %}
{% set mainImg = extras.pathImg is defined and extras.pictures is defined and extras.pictures|length > 0 
    ? extras.pathImg ~ '/' ~ extras.pictures[0] 
    : item.thumb %}
{% set title = extras.fuente is defined and extras.fuente != ""
    ? extras.fuente 
    : item.title %}
{% set placeholder = 'https://placehold.co/600x600/0f172a/64748b?text=Sin+Imagen' %}

<div class="group bg-slate-900 border border-slate-800 rounded-3xl overflow-hidden hover:border-primary/50 transition-all duration-300 flex flex-col shadow-lg hover:shadow-primary/5 active:scale-[0.98]">
    <!-- Image Area -->
    <div class="relative aspect-square overflow-hidden bg-slate-950 cursor-pointer" @click="openModal({{ {
        id: item.id,
        title: title,
        price: item.price,
        thumb: mainImg,
        imgBig: mainImg,
        detalles: item.detalles|default('Sin detalles adicionales.'),
        sku: item.iku|default('N/A'),
        brand: item.mrkId,
        model: item.mdlId,
        pictures: extras.pictures|default([]),
        pathImg: extras.pathImg|default('')
    }|json_encode|e('html_attr') }})">
        <img src="{{ mainImg }}" 
             onerror="this.src='{{ placeholder }}'"
             class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 opacity-90 group-hover:opacity-100" 
             alt="{{ title }}">
        
        <!-- Status Badge -->
        {% if item.isActive %}
            <span class="absolute top-3 left-3 bg-emerald-500/10 text-primary text-[9px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full border border-emerald-500/20 backdrop-blur-md">
                Disponible
            </span>
        {% endif %}
    </div>

    <!-- Info Area -->
    <div class="p-5 flex-1 flex flex-col">
        <div class="flex-1">
            <h3 class="text-base font-bold text-slate-200 line-clamp-2 leading-tight group-hover:text-primary transition-colors cursor-pointer min-h-[2.5rem]" 
                @click="openModal({{ {
                    id: item.id,
                    title: title,
                    price: item.price,
                    thumb: mainImg,
                    imgBig: mainImg,
                    detalles: item.detalles|default('Sin detalles adicionales.'),
                    sku: item.iku|default('N/A'),
                    brand: item.mrkId,
                    model: item.mdlId,
                    pictures: extras.pictures|default([]),
                    pathImg: extras.pathImg|default('')
                }|json_encode|e('html_attr') }})">
                {{ title }}
            </h3>
            <p class="text-[9px] text-slate-500 font-bold uppercase tracking-wider mt-1">SKU: {{ item.iku|default('N/A') }}</p>
        </div>

        <div class="mt-4 pt-4 border-t border-slate-800/50 flex items-center justify-between gap-2">
            <div class="flex flex-col min-w-0">
                <span class="text-xl font-black text-white italic truncate">
                    ${{ item.price|number_format(2, '.', ',') }}
                </span>
                <span class="text-[9px] text-slate-500">MXN + Envío</span>
            </div>
            
            <button @click="addToCart({{ item.id }})" 
                    class="p-3 bg-slate-800 hover:bg-primary text-slate-400 hover:text-darker rounded-xl transition-all shadow-lg active:scale-90 flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
            </button>
        </div>
    </div>
</div>
