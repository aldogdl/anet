<!-- Logo & Mini Contact Section -->
<div class="p-6 flex flex-col items-center border-b border-slate-800">
    <div class="w-24 h-24 bg-slate-800 rounded-xl flex items-center justify-center overflow-hidden mb-3 border border-slate-700 shadow-inner">
        <span class="text-2xl font-bold text-primary italic">LOGO</span>
    </div>
    <h2 class="text-sm font-bold text-white tracking-tight">{{ storeName|default('Mi Tienda') }}</h2>
    
    <!-- Ultra Compact Contact Line -->
    <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 mt-2 text-[10px] text-slate-300 font-semibold">
        <div class="flex items-center gap-1">
            <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
            <span class="text-white">Online</span>
        </div>
        <div class="flex items-center gap-1 border-l border-slate-700 pl-3">
            <svg class="w-3 h-3 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            <span class="text-white text-[13px]">55 1234 5678</span>
        </div>
        <div class="flex items-center gap-1 border-l border-slate-700 pl-3">
            <svg class="w-3 h-3 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
            <span class="text-white">CDMX</span>
        </div>
    </div>
</div>

<!-- Brands Filter (Scrollable) -->
<div class="flex-1 overflow-hidden flex flex-col p-6" x-data="{ 
    filters: [], 
    loading: true,
    async fetchFilters() {
        try {
            const res = await fetch('{{ path('muro_shop_filters', {slug: slug}) }}?t=' + Date.now());
            this.filters = await res.json();
            console.log('Filtros cargados:', this.filters);
        } finally {
            this.loading = false;
        }
    }
}" x-init="fetchFilters()">
    <h3 class="text-[10px] font-black text-slate-200 uppercase tracking-widest mb-4 flex items-center justify-between">
        FILTROS DE MARCAS
        <span class="bg-primary text-darker px-1.5 py-0.5 rounded text-[9px] font-bold" x-text="filters.length"></span>
    </h3>
    
    <div class="flex-1 overflow-y-auto space-y-1 -mx-2 px-2" id="brands-list">
        <template x-if="loading">
            <div class="p-4 text-center">
                <span class="text-[10px] text-primary animate-pulse font-bold tracking-widest">CARGANDO FILTROS...</span>
            </div>
        </template>
        
        <template x-if="!loading && filters.length === 0">
            <div class="p-4 text-center border border-dashed border-slate-800 rounded-xl">
                <span class="text-[10px] text-slate-500 font-bold">SIN MARCAS DISPONIBLES</span>
            </div>
        </template>
        
        <template x-for="brand in filters" :key="brand.id">
            <div class="group" x-data="{ open: false }">
                <!-- Brand Row -->
                <button @click="open = !open" 
                        class="w-full flex items-center justify-between py-1.5 px-3 rounded-lg hover:bg-[#10b981]/10 transition-all border border-transparent hover:border-[#10b981]/20">
                    <div class="flex items-center gap-2">
                        <!-- Chevron Icon -->
                        <svg class="w-3 h-3 text-[#10b981] transition-transform duration-300" 
                             :class="open ? 'rotate-90' : ''"
                             fill="none" stroke="currentColor" viewBox="0 0 24 24">
                             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path>
                        </svg>
                        <span class="font-black text-xs uppercase tracking-tight" 
                              style="color: #10b981 !important;" 
                              x-text="brand.name || JSON.stringify(brand)"></span>
                    </div>
                    <span class="text-white font-black bg-blue-600 px-2 py-0.5 rounded shadow-sm border border-blue-400/30" 
                          x-text="brand.count"></span>
                </button>

                <!-- Models List (Accordion) -->
                <div x-show="open" 
                     x-collapse 
                     class="ml-6 mt-1 mb-2 space-y-1 border-l-2 border-slate-800 pl-3">
                    <template x-for="model in brand.models" :key="model.id">
                        <button class="w-full flex items-center justify-between py-2 px-3 rounded-md text-xs font-bold text-white tracking-widest uppercase hover:bg-white/10 hover:text-primary transition-all text-left">
                            <span x-text="model.name"></span>
                            <span class="text-[10px] bg-dark px-1.5 py-0.5 rounded border border-slate-700" x-text="model.count"></span>
                        </button>
                    </template>
                    <template x-if="brand.models.length === 0">
                        <span class="text-[10px] text-slate-500 font-bold italic px-3 block py-2">SIN MODELOS DISPONIBLES</span>
                    </template>
                </div>
            </div>
        </template>
    </div>
</div>

<!-- Footer Action (Fixed) -->
<div class="p-6 bg-dark/30 border-t border-slate-800">
    <div class="mb-4 text-center">
        <h4 class="text-[10px] font-black text-slate-300 uppercase tracking-widest mb-3 italic">¿No encontraste tu pieza?</h4>
        <button class="mx-auto w-3/4 bg-blue-600 hover:bg-blue-500 text-white font-black py-3 rounded-xl text-[10px] transition-all flex items-center justify-center gap-2 group shadow-lg active:scale-95 border border-blue-400/20 shadow-blue-600/20">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
            SOLICITAR PIEZA
        </button>
    </div>
    
    <div class="pt-3 border-t border-slate-800/50">
        <p class="text-[9px] text-slate-400 font-bold flex items-center justify-center gap-1">
            Un producto mas de <span class="text-white">YonkEros <span class="text-primary">®</span></span>
        </p>
    </div>
</div>
